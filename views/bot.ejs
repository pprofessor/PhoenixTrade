<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
        body { background: #f0f4f0; display: flex; min-height: 100vh; }
        .sidebar { width: 280px; background: linear-gradient(180deg, #0b3b2c, #1a6d4c); color: white; position: fixed; height: 100vh; }
        .sidebar-header { padding: 30px 24px; border-bottom: 1px solid rgba(255,215,0,0.2); }
.sidebar-header h2 { 
    font-size: 24px; 
    background: linear-gradient(135deg, #fff, #d4af37); 
    -webkit-background-clip: text; 
    background-clip: text; 
    -webkit-text-fill-color: transparent; 
    color: transparent; 
}        .nav-menu { padding: 20px 0; }
        .nav-item { padding: 12px 24px; margin: 4px 8px; border-radius: 12px; display: flex; align-items: center; gap: 12px; color: #e0f0e0; text-decoration: none; }
        .nav-item:hover, .nav-item.active { background: rgba(255,255,255,0.1); color: #d4af37; }
        .main-content { margin-right: 280px; flex: 1; padding: 30px; width: calc(100% - 280px); }
        .header { background: white; padding: 20px 30px; border-radius: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { color: #0b3b2c; }
        .add-btn { background: #1a6d4c; color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; }
        .messages-grid { display: grid; gap: 20px; }
        .message-card { background: white; border-radius: 20px; padding: 20px; border: 1px solid #eef2f0; }
        .message-key { background: #f0f4f0; padding: 5px 10px; border-radius: 8px; color: #0b3b2c; font-weight: 600; display: inline-block; margin-bottom: 10px; }
        .message-text { color: #4b5563; margin-bottom: 15px; }
        .message-actions { display: flex; gap: 10px; }
        .message-actions a { padding: 5px 15px; border-radius: 8px; text-decoration: none; font-size: 13px; }
        .edit-btn { background: #f0f4f0; color: #0b3b2c; }
        .delete-btn { background: #fee2e2; color: #dc2626; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <h2>PhoenixTrade</h2>
        </div>
        <div class="nav-menu">
            <a href="/pprofessor/dashboard" class="nav-item">📊 داشبورد</a>
            <a href="/pprofessor/lessons" class="nav-item">📚 درس‌ها</a>
            <a href="/pprofessor/brokers" class="nav-item">🏢 بروکرها</a>
            <a href="/pprofessor/events" class="nav-item">📅 رویدادها</a>
            <a href="/pprofessor/bot" class="nav-item active">🤖 ربات</a>
            <a href="/pprofessor/webapp" class="nav-item">🌐 WebApp</a>
            <a href="/pprofessor/backup" class="nav-item">💾 بکاپ</a>
            <a href="/pprofessor/api" class="nav-item">🔧 API</a>
        </div>
    </div>
    
    <div class="main-content">
        <div class="header">
            <h1><%= title %></h1>
            <a href="/pprofessor/bot/messages/new" class="add-btn">+ پیام جدید</a>
        </div>
        
        <div class="messages-grid">
            <% messages.forEach(message => { %>
            <div class="message-card">
                <div class="message-key"><%= message.key %></div>
                <div class="message-text"><%= message.text %></div>
                <div class="message-actions">
                    <a href="/pprofessor/bot/messages/<%= message.id %>/edit" class="edit-btn">ویرایش</a>
                    <a href="/pprofessor/bot/messages/<%= message.id %>/delete" class="delete-btn" onclick="return confirm('حذف شود؟')">حذف</a>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</body>
</html>