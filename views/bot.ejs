<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <!-- استایل مخصوص صفحه ربات -->
    <style>
        /* ===== تب‌ها ===== */
        .tabs {
            display: flex;
            gap: 0.8rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }
        
        .tab {
            padding: 0.6rem 1.8rem;
            background: rgba(255,255,255,0.05);
            border-radius: 25px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255,215,0,0.2);
            font-size: 0.95rem;
        }
        
        .tab:hover {
            border-color: #ffd700;
        }
        
        .tab.active {
            background: #ffd700;
            color: #0a2f1f;
            font-weight: bold;
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        /* ===== کارت‌ها ===== */
        .card {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,215,0,0.2);
        }
        
        .card h3 {
            color: #ffd700;
            margin-bottom: 1.2rem;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            border-bottom: 1px solid rgba(255,215,0,0.2);
            padding-bottom: 0.8rem;
        }
        
        /* ===== فرم‌ها ===== */
        .form-group {
            margin-bottom: 1.2rem;
        }
        
        .form-group label {
            display: block;
            color: #ffd700;
            margin-bottom: 0.4rem;
            font-weight: bold;
            font-size: 0.95rem;
        }
        
        .form-control {
            width: 100%;
            padding: 0.8rem 1rem;
            border-radius: 12px;
            border: 1px solid rgba(255,215,0,0.2);
            background: rgba(0,0,0,0.3);
            color: #fff;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #ffd700;
        }
        
        select.form-control {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ffd700'%3e%3cpath d='M7 10l5 5 5-5z'/%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: left 1rem center;
            background-size: 1rem;
        }
        
        /* ===== نوار ابزار رسانه ===== */
        .media-toolbar {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            flex-wrap: wrap;
        }
        
        .media-btn {
            background: rgba(255,215,0,0.1);
            border: 1px solid rgba(255,215,0,0.3);
            color: #ffd700;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.2s;
        }
        
        .media-btn:hover {
            background: #ffd700;
            color: #0a2f1f;
        }
        
        .media-preview {
            margin-top: 0.5rem;
            padding: 0.5rem;
            background: rgba(0,0,0,0.2);
            border-radius: 10px;
            font-size: 0.85rem;
            color: #aaa;
            display: none;
        }
        
        /* ===== ایموجی‌پیکر ===== */
        .emoji-picker {
            display: grid;
            grid-template-columns: repeat(10, 1fr);
            gap: 0.3rem;
            margin-top: 0.5rem;
            max-height: 150px;
            overflow-y: auto;
            padding: 0.8rem;
            background: rgba(0,0,0,0.3);
            border-radius: 12px;
        }
        
        .emoji-item {
            font-size: 1.2rem;
            padding: 0.3rem;
            text-align: center;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.2s;
        }
        
        .emoji-item:hover {
            background: #ffd700;
            transform: scale(1.1);
        }
        
        .emoji-clear {
            grid-column: span 10;
            margin-top: 0.3rem;
        }
        
        .emoji-clear button {
            width: 100%;
            background: rgba(255,215,0,0.1);
            border: 1px dashed #ffd700;
            color: #ffd700;
            padding: 0.4rem;
            border-radius: 15px;
            cursor: pointer;
            font-size: 0.85rem;
        }
        
        .emoji-clear button:hover {
            background: #ffd700;
            color: #0a2f1f;
        }
        
        /* ===== ساختار درختی ===== */
        .menu-tree {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            margin: 1rem 0;
        }
        
        .menu-node {
            background: rgba(26, 59, 46, 0.8);
            border-radius: 8px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            overflow: hidden;
        }
        
        .menu-node.main-node {
            border-right: 3px solid #ffd700;
        }
        
        .menu-node.sub-node {
            margin-right: 15px;
            border-right: 2px solid #b8860b;
        }
        
        .menu-header {
            padding: 0.6rem 1rem;
            background: rgba(0, 0, 0, 0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .menu-title-section {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .menu-emoji {
            font-size: 1rem;
        }
        
        .menu-text {
            color: #fff;
            font-size: 0.9rem;
            font-weight: 500;
        }
        
        .main-badge {
            background: #ffd700;
            color: #0a2f1f;
            padding: 0.1rem 0.6rem;
            border-radius: 12px;
            font-size: 0.7rem;
            margin-right: 0.5rem;
        }
        
        .menu-content-preview {
            padding: 0.5rem 1rem;
            background: rgba(0,0,0,0.1);
            font-size: 0.8rem;
            color: #ccc;
            border-top: 1px dashed rgba(255,215,0,0.2);
        }
        
        .children-container {
            margin-right: 15px;
            padding-right: 8px;
            border-right: 1px dashed rgba(255,215,0,0.2);
        }
        
        /* ===== دکمه‌ها ===== */
        .btn {
            background: linear-gradient(135deg, #ffd700, #b8860b);
            color: #0a2f1f;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 25px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.95rem;
        }
        
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255,215,0,0.3);
        }
        
        .btn-sm {
            padding: 0.4rem 1.2rem;
            font-size: 0.85rem;
        }
        
        .btn-danger {
            background: linear-gradient(135deg, #dc3545, #a71d2a);
            color: #fff;
        }
        
        /* ===== وضعیت ربات ===== */
        .bot-status {
            background: rgba(0,0,0,0.3);
            border-radius: 30px;
            padding: 1.2rem 1.5rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            border: 1px solid rgba(255,215,0,0.3);
        }
        
        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: rgba(0,0,0,0.3);
            padding: 0.5rem 1.2rem;
            border-radius: 30px;
        }
        
        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #0f0;
            box-shadow: 0 0 10px #0f0;
        }
        
        .token-edit {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
            min-width: 300px;
        }
        
        .token-edit input {
            flex: 1;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,215,0,0.3);
            border-radius: 30px;
            padding: 0.6rem 1rem;
            color: #ffd700;
            font-family: monospace;
            direction: ltr;
        }
        
        /* ===== جدول کاربران ===== */
        .table-container {
            overflow-x: auto;
            border-radius: 15px;
            background: rgba(0,0,0,0.2);
            padding: 1rem;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        
        .data-table th {
            background: rgba(255,215,0,0.1);
            color: #ffd700;
            padding: 0.8rem;
            font-weight: bold;
        }
        
        .data-table td {
            padding: 0.8rem;
            color: #fff;
            border-bottom: 1px solid rgba(255,215,0,0.1);
        }
    </style>
</head>
<body>
    <div id="toast" class="toast"></div>

    <!-- سایدبار -->
    <%- include('sidebar') %>

    <!-- محتوای اصلی -->
    <div class="main-content">
        <div class="header">
            <h1><i class="fas fa-robot"></i> مدیریت ربات هوشمند</h1>
        </div>

        <!-- وضعیت ربات با قابلیت ویرایش توکن -->
        <div class="bot-status">
            <div class="status-indicator">
                <span class="status-dot"></span>
                <span style="color: #fff;" id="bot-status-text">بررسی وضعیت...</span>
            </div>
            <div class="token-edit">
                <input type="text" id="bot-token" value="8223148206:AAGIN2pqe7we5TPU8jNDDISoCFYm2FfhonQ" placeholder="توکن ربات">
                <button class="btn btn-sm" onclick="saveBotToken()"><i class="fas fa-save"></i> ذخیره</button>
            </div>
            <button class="btn btn-sm" onclick="testBot()"><i class="fas fa-sync-alt"></i> تست</button>
        </div>

        <!-- تب‌ها -->
        <div class="tabs">
            <div class="tab active" onclick="showTab('messages')">پیام‌ها</div>
            <div class="tab" onclick="showTab('menus')">منوها</div>
            <div class="tab" onclick="showTab('users')">کاربران</div>
        </div>

        <!-- تب پیام‌ها -->
        <div id="tab-messages" class="tab-content active">
            <div class="card">
                <h3><i class="fas fa-comment"></i> پیام‌های ربات</h3>
                
                <div class="form-group">
                    <label>پیام خوش‌آمدگویی (کاربران جدید)</label>
                    <textarea id="welcome-new" class="form-control" rows="3"><% 
                        let welcomeNew = messages ? messages.find(m => m.key === 'welcome_new') : null;
                        %><%= welcomeNew ? welcomeNew.text : 'به ربات خوش آمدید' %></textarea>
                </div>

                <div class="form-group">
                    <label>پیام خوش‌آمدگویی (کاربران قبلی)</label>
                    <textarea id="welcome-return" class="form-control" rows="3"><% 
                        let welcomeReturn = messages ? messages.find(m => m.key === 'welcome_return') : null;
                        %><%= welcomeReturn ? welcomeReturn.text : 'خوش آمدید' %></textarea>
                </div>

                <button class="btn" onclick="saveMessages()"><i class="fas fa-save"></i> ذخیره پیام‌ها</button>
            </div>
        </div>

        <!-- تب منوها -->
        <div id="tab-menus" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-sitemap"></i> ساختار درختی منوها</h3>
                
                <button class="btn" onclick="showMenuForm()" style="margin-bottom:1rem;">
                    <i class="fas fa-plus-circle"></i> ایجاد منوی جدید
                </button>

                <!-- نمایش درختی منوها -->
                <div class="menu-tree">
                    <% if (menuTree && menuTree.length > 0) { 
                        function renderMenu(menu, level = 0) { %>
                            <div class="menu-node <%= menu.parentId ? 'sub-node' : 'main-node' %>" style="margin-right: <%= level * 12 %>px;">
                                <div class="menu-header">
                                    <div class="menu-title-section">
                                        <span class="menu-emoji"><%= menu.emoji || '🔹' %></span>
                                        <span class="menu-text">
                                            <%= menu.text %>
                                            <% if (!menu.parentId) { %>
                                                <span class="main-badge">اصلی</span>
                                            <% } %>
                                        </span>
                                    </div>
                                    <div class="menu-actions">
                                        <button class="btn btn-sm" onclick="editMenu('<%= menu.id %>')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteMenu('<%= menu.id %>')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                                
                                <% if (menu.content) { %>
                                    <div class="menu-content-preview">
                                        <i class="fas fa-align-left"></i>
                                        <%= menu.content.length > 80 ? menu.content.substring(0, 80) + '...' : menu.content %>
                                    </div>
                                <% } %>
                                
                                <% if (menu.children && menu.children.length > 0) { %>
                                    <div class="children-container">
                                        <% menu.children.forEach(child => { %>
                                            <% renderMenu(child, level + 1); %>
                                        <% }); %>
                                    </div>
                                <% } %>
                            </div>
                        <% } %>
                        
                        <% menuTree.forEach(menu => { %>
                            <% renderMenu(menu, 0); %>
                        <% }); %>
                    <% } else { %>
                        <div style="text-align:center; padding:2rem; color:#aaa;">
                            <i class="fas fa-folder-open" style="font-size:2rem; color:#ffd700;"></i>
                            <p>هیچ منویی تعریف نشده است</p>
                        </div>
                    <% } %>
                </div>

                <!-- فرم ایجاد/ویرایش منو -->
                <div id="menu-form" style="display:none; margin-top:2rem; padding-top:1.5rem; border-top:1px dashed rgba(255,215,0,0.3);">
                    <h4 id="menu-form-title" style="color:#ffd700; margin-bottom:1.5rem; font-size:1.3rem;">
                        <i class="fas fa-edit"></i> ایجاد منوی جدید
                    </h4>
                    <input type="hidden" id="menu-id">
                    
                    <div class="form-group">
                        <label>📝 متن نمایشی منو</label>
                        <input type="text" id="menu-text" class="form-control" placeholder="مثلاً: دوره‌های آموزشی" required>
                    </div>

                    <div class="form-group">
                        <label>🔗 منوی والد</label>
                        <select id="menu-parent" class="form-control">
                            <option value="">-- منوی اصلی --</option>
                            <% if (allMenus && allMenus.length > 0) { 
                                function renderMenuOption(menu, level = 0) { %>
                                    <option value="<%= menu.id %>">
                                        <%= '•'.repeat(level) %> <%= ' '.repeat(level) %> <%= menu.emoji || '🔹' %> <%= menu.text %>
                                    </option>
                                    <% if (menu.children && menu.children.length > 0) { %>
                                        <% menu.children.forEach(child => { %>
                                            <% renderMenuOption(child, level + 1); %>
                                        <% }); %>
                                    <% } %>
                                <% } %>
                                <% menuTree.forEach(menu => { %>
                                    <% renderMenuOption(menu, 0); %>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>📄 متن نمایشی با قابلیت رسانه</label>
                        <!-- نوار ابزار رسانه -->
                        <div class="media-toolbar">
                            <button type="button" class="media-btn" onclick="insertMedia('photo')">
                                <i class="fas fa-image"></i> عکس
                            </button>
                            <button type="button" class="media-btn" onclick="insertMedia('video')">
                                <i class="fas fa-video"></i> ویدئو
                            </button>
                            <button type="button" class="media-btn" onclick="insertMedia('audio')">
                                <i class="fas fa-music"></i> صوت
                            </button>
                            <button type="button" class="media-btn" onclick="insertMedia('file')">
                                <i class="fas fa-file"></i> فایل
                            </button>
                        </div>
                        <!-- فیلد آپلود مخفی -->
                        <input type="file" id="media-upload" style="display:none;" accept="image/*,video/*,audio/*,application/pdf">
                        <!-- پیش‌نمایش رسانه -->
                        <div id="media-preview" class="media-preview"></div>
                        <!-- متن اصلی -->
                        <textarea id="menu-content" class="form-control" rows="4" placeholder="متن یا اطلاعاتی که نمایش داده می‌شود..."></textarea>
                        <small style="color:#aaa;">برای افزودن رسانه، روی دکمه‌های بالا کلیک کنید و فایل را انتخاب کنید</small>
                    </div>

                    <div class="form-group">
                        <label>😊 ایموجی (اختیاری)</label>
                        <div class="emoji-picker">
                            <!-- 50 ایموجی پرکاربرد -->
                            <div class="emoji-item" onclick="selectEmoji('🔹')">🔹</div>
                            <div class="emoji-item" onclick="selectEmoji('📚')">📚</div>
                            <div class="emoji-item" onclick="selectEmoji('💹')">💹</div>
                            <div class="emoji-item" onclick="selectEmoji('📅')">📅</div>
                            <div class="emoji-item" onclick="selectEmoji('👤')">👤</div>
