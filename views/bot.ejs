                            <div class="emoji-item" onclick="selectEmoji('😋')">😋</div>
                            <div class="emoji-item" onclick="selectEmoji('😛')">😛</div>
                            <div class="emoji-item" onclick="selectEmoji('😜')">😜</div>
                            <div class="emoji-item" onclick="selectEmoji('🤪')">🤪</div>
                            <div class="emoji-item" onclick="selectEmoji('😝')">😝</div>
                            <div class="emoji-item" onclick="selectEmoji('🤑')">🤑</div>
                            <div class="emoji-item" onclick="selectEmoji('🤗')">🤗</div>
                            <div class="emoji-item" onclick="selectEmoji('🤔')">🤔</div>
                            <div class="emoji-item" onclick="selectEmoji('🤐')">🤐</div>
                            <div class="emoji-item" onclick="selectEmoji('😐')">😐</div>
                            <div class="emoji-item" onclick="selectEmoji('😑')">😑</div>
                            <div class="emoji-clear">
                                <button onclick="clearEmoji()">❌ بدون ایموجی</button>
                            </div>
                        </div>
                        <input type="text" id="menu-emoji" class="form-control" style="margin-top:0.5rem;" placeholder="ایموجی انتخاب شده">
                    </div>

                    <div class="form-group">
                        <label>🔢 ترتیب نمایش</label>
                        <input type="number" id="menu-order" class="form-control" value="0" min="0">
                    </div>

                    <div style="display:flex; gap:1rem; margin-top:1.5rem;">
                        <button class="btn" onclick="saveMenu()"><i class="fas fa-save"></i> ذخیره منو</button>
                        <button class="btn btn-danger" onclick="cancelMenuForm()"><i class="fas fa-times"></i> انصراف</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- تب کاربران -->
        <div id="tab-users" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-users"></i> کاربران ربات</h3>
                
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>نام</th>
                                <th>نام خانوادگی</th>
                                <th>یوزرنیم</th>
                                <th>تاریخ ثبت</th>
                            </tr>
                        </thead>
                        <tbody id="users-container">
                            <tr><td colspan="4" style="text-align:center;">در حال بارگذاری...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============= متغیرهای سراسری =============
        let selectedMediaFile = null;

        // ============= توابع کمکی =============
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.className = 'toast ' + type;
            toast.textContent = message;
            toast.style.display = 'block';
            setTimeout(() => toast.style.display = 'none', 2000);
        }

        function showTab(tabName) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('tab-' + tabName).classList.add('active');
            if (tabName === 'users') loadUsers();
        }

        // ============= مدیریت توکن =============
        function saveBotToken() {
            const token = document.getElementById('bot-token').value;
            // اینجا می‌توانید توکن را در دیتابیس ذخیره کنید
            showToast('✅ توکن با موفقیت ذخیره شد');
        }

        function testBot() {
            fetch('/pprofessor/api/bot/status')
                .then(res => res.json())
                .then(data => {
                    if (data.online) {
                        document.getElementById('bot-status-text').innerHTML = '✅ آنلاین - @' + data.username;
                        showToast('✅ ربات آنلاین است');
                    } else {
                        document.getElementById('bot-status-text').innerHTML = '❌ آفلاین';
                        showToast('❌ ربات آفلاین است', 'error');
                    }
                })
                .catch(() => {
                    document.getElementById('bot-status-text').innerHTML = '❌ خطا';
                    showToast('❌ خطا در اتصال', 'error');
                });
        }

        // ============= مدیریت رسانه =============
        function insertMedia(type) {
            const input = document.getElementById('media-upload');
            input.accept = type === 'photo' ? 'image/*' : 
                          type === 'video' ? 'video/*' : 
                          type === 'audio' ? 'audio/*' : '*/*';
            input.onchange = function(e) {
                const file = e.target.files[0];
                if (file) {
                    selectedMediaFile = file;
                    
                    const preview = document.getElementById('media-preview');
                    const content = document.getElementById('menu-content');
                    
                    let icon = type === 'photo' ? '🖼️' : 
                              type === 'video' ? '🎬' : 
                              type === 'audio' ? '🎵' : '📎';
                    
                    preview.innerHTML = `${icon} ${file.name} (${(file.size/1024).toFixed(1)} KB) - آماده آپلود`;
                    preview.style.display = 'block';
                    
                    let mediaTag = `[${type === 'photo' ? 'عکس' : type === 'video' ? 'ویدئو' : type === 'audio' ? 'صوت' : 'فایل'}: ${file.name}]`;
                    content.value += (content.value ? '\n' : '') + mediaTag;
                }
            };
            input.click();
        }

        // ============= مدیریت ایموجی =============
        function selectEmoji(emoji) {
            document.getElementById('menu-emoji').value = emoji;
        }

        function clearEmoji() {
            document.getElementById('menu-emoji').value = '';
        }

        // ============= مدیریت منوها =============
        function showMenuForm() {
            document.getElementById('menu-form').style.display = 'block';
            document.getElementById('menu-form-title').innerHTML = '<i class="fas fa-plus-circle"></i> ایجاد منوی جدید';
            document.getElementById('menu-id').value = '';
            document.getElementById('menu-text').value = '';
            document.getElementById('menu-parent').value = '';
            document.getElementById('menu-emoji').value = '';
            document.getElementById('menu-content').value = '';
            document.getElementById('menu-order').value = '0';
            document.getElementById('media-preview').style.display = 'none';
            selectedMediaFile = null;
        }

        function editMenu(id) {
            fetch('/pprofessor/api/bot/menus')
                .then(res => res.json())
                .then(menus => {
                    let menu = menus.find(m => m.id == id);
                    if (menu) {
                        document.getElementById('menu-form').style.display = 'block';
                        document.getElementById('menu-form-title').innerHTML = '<i class="fas fa-edit"></i> ویرایش منو';
                        document.getElementById('menu-id').value = menu.id;
                        document.getElementById('menu-text').value = menu.text || '';
                        document.getElementById('menu-parent').value = menu.parentId || '';
                        document.getElementById('menu-emoji').value = menu.emoji || '';
                        document.getElementById('menu-content').value = menu.content || '';
                        document.getElementById('menu-order').value = menu.order || 0;
                        document.getElementById('media-preview').style.display = 'none';
                        selectedMediaFile = null;
                    }
                });
        }

        function saveMenu() {
            let id = document.getElementById('menu-id').value;
            
            // اعتبارسنجی
            if (!document.getElementById('menu-text').value) {
                showToast('❌ متن منو نمی‌تواند خالی باشد', 'error');
                return;
            }
            
            // آماده‌سازی داده‌ها
            let formData = new FormData();
            formData.append('text', document.getElementById('menu-text').value);
            formData.append('emoji', document.getElementById('menu-emoji').value || '');
            formData.append('content', document.getElementById('menu-content').value);
            formData.append('order', parseInt(document.getElementById('menu-order').value) || 0);
            formData.append('parentId', document.getElementById('menu-parent').value || '');
            
            // اضافه کردن فایل اگر انتخاب شده باشد
            if (selectedMediaFile) {
                formData.append('media', selectedMediaFile);
            }
            
            let url = id ? '/pprofessor/api/bot/menus/' + id : '/pprofessor/api/bot/menus';
            let method = id ? 'PUT' : 'POST';
            
            fetch(url, {
                method: method,
                body: formData
            })
            .then(res => res.json())
            .then(result => {
                if (result.error) {
                    showToast('❌ ' + result.error, 'error');
                } else {
                    showToast(id ? '✅ منو ویرایش شد' : '✅ منو ایجاد شد');
                    setTimeout(() => location.reload(), 1000);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('❌ خطا در ذخیره منو', 'error');
            });
        }

        function deleteMenu(id) {
            if (confirm('آیا از حذف این منو اطمینان دارید؟')) {
                fetch('/pprofessor/api/bot/menus/' + id, { method: 'DELETE' })
                .then(res => res.json())
                .then(result => {
                    if (result.error) {
                        showToast('❌ ' + result.error, 'error');
                    } else {
                        showToast('✅ منو حذف شد');
                        setTimeout(() => location.reload(), 1000);
                    }
                })
                .catch(() => showToast('❌ خطا در حذف منو', 'error'));
            }
        }

        function cancelMenuForm() {
            document.getElementById('menu-form').style.display = 'none';
        }

        // ============= مدیریت کاربران =============
        function loadUsers() {
            fetch('/pprofessor/api/bot/users')
                .then(res => res.json())
                .then(users => {
                    let html = '';
                    if (users.length === 0) {
                        html = '<tr><td colspan="4" style="text-align:center;">کاربری یافت نشد</td></tr>';
                    } else {
                        users.forEach(u => {
                            let date = new Date(u.createdAt).toLocaleDateString('fa-IR');
                            html += '<tr>' +
                                '<td>' + (u.firstName || '-') + '</td>' +
                                '<td>' + (u.lastName || '-') + '</td>' +
                                '<td>' + (u.username || '-') + '</td>' +
                                '<td>' + date + '</td>' +
                                '</tr>';
                        });
                    }
                    document.getElementById('users-container').innerHTML = html;
                });
        }

        // ============= مدیریت پیام‌ها =============
        function saveMessages() {
            const messages = [
                { key: 'welcome_new', text: document.getElementById('welcome-new').value },
                { key: 'welcome_return', text: document.getElementById('welcome-return').value }
            ];
            
            Promise.all(messages.map(msg => 
                fetch('/pprofessor/api/bot/messages', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(msg)
                })
            ))
            .then(() => showToast('✅ پیام‌ها ذخیره شدند'))
            .catch(() => showToast('❌ خطا در ذخیره پیام‌ها', 'error'));
        }

        // ============= تست اولیه =============
        testBot();
    </script>
</body>
</html>