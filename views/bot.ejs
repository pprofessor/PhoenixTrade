                            <div class="emoji-item" onclick="selectEmoji('⚡')">⚡</div>
                            <div class="emoji-item" onclick="selectEmoji('⭐')">⭐</div>
                            <div class="emoji-item" onclick="selectEmoji('🏠')">🏠</div>
                            <div class="emoji-item" onclick="selectEmoji('📊')">📊</div>
                            <div class="emoji-item" onclick="selectEmoji('📈')">📈</div>
                            <div class="emoji-item" onclick="selectEmoji('💰')">💰</div>
                            <div class="emoji-item" onclick="selectEmoji('🔔')">🔔</div>
                            <div class="emoji-item" onclick="selectEmoji('⚙️')">⚙️</div>
                            <div class="emoji-item" onclick="selectEmoji('🔗')">🔗</div>
                            <div class="emoji-item" onclick="selectEmoji('🎯')">🎯</div>
                            <div class="emoji-item" onclick="selectEmoji('💡')">💡</div>
                            <div class="emoji-item" onclick="selectEmoji('🔥')">🔥</div>
                            <div class="emoji-item" onclick="selectEmoji('✨')">✨</div>
