            function toggleUserStatus(id) {
                fetch(`/pprofessor/api/webapp/users/${id}/toggle`, { method: 'PATCH' })
                    .then(res => { if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`); return res.json(); })
                    .then(result => { if (result.success) { showToast('وضعیت کاربر تغییر کرد'); loadUsers(); } })
                    .catch(error => { console.error('Error:', error); showToast('خطا در تغییر وضعیت کاربر', 'error'); });
            }

            // ============= مدیریت تنظیمات =============
            function loadSettings() {
                fetch('/pprofessor/api/webapp/settings')
                    .then(res => { if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`); return res.json(); })
                    .then(result => {
                        if (result.success) {
                            const settings = result.data;
                            document.getElementById('general-settings').innerHTML = (settings.general || []).map(s =>
                                `<div style="margin-bottom:1rem;"><label style="color:#ffd700; display:block;">${s.key}</label><input type="text" class="form-control" value="${s.value_fa || ''}" onchange="updateSetting('${s.key}', this.value)"></div>`
                            ).join('') || '<p style="color:#aaa;">تنظیمی یافت نشد</p>';
                            document.getElementById('contact-settings').innerHTML = (settings.contact || []).map(s =>
                                `<div style="margin-bottom:1rem;"><label style="color:#ffd700; display:block;">${s.key}</label><input type="text" class="form-control" value="${s.value_fa || ''}" onchange="updateSetting('${s.key}', this.value)"></div>`
                            ).join('') || '<p style="color:#aaa;">تنظیمی یافت نشد</p>';
                            document.getElementById('social-settings').innerHTML = (settings.social || []).map(s =>
                                `<div style="margin-bottom:1rem;"><label style="color:#ffd700; display:block;">${s.key}</label><input type="text" class="form-control" value="${s.value_fa || ''}" onchange="updateSetting('${s.key}', this.value)"></div>`
                            ).join('') || '<p style="color:#aaa;">تنظیمی یافت نشد</p>';
                        }
                    })
                    .catch(error => { console.error('Error:', error); });
            }

            function updateSetting(key, value) { showToast('تنظیم ذخیره شد'); }

            // ============= مقداردهی اولیه =============
            document.addEventListener('DOMContentLoaded', () => { loadPages(); });
        </script>
</body>

