<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* ===== استایل‌های اختصاصی صفحه وب‌اپ ===== */
        
        .tabs {
            display: flex;
            gap: 0.8rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }
        
        .tab {
            padding: 0.6rem 1.8rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 25px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255, 215, 0, 0.2);
            font-size: 0.95rem;
        }
        
        .tab:hover {
            border-color: #ffd700;
        }
        
        .tab.active {
            background: #ffd700;
            color: #0a2f1f;
            font-weight: bold;
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        
        .stat-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 1.2rem;
            text-align: center;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .stat-value {
            color: #ffd700;
            font-size: 1.8rem;
            font-weight: bold;
        }
        
        .stat-label {
            color: #aaa;
            margin-top: 0.3rem;
            font-size: 0.9rem;
        }
        
        .card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .card h3 {
            color: #ffd700;
            margin-bottom: 1.2rem;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
        
        .table-container {
            overflow-x: auto;
            border-radius: 12px;
            background: rgba(0, 0, 0, 0.2);
            padding: 0.5rem;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        
        .data-table th {
            background: rgba(255, 215, 0, 0.15);
            color: #ffd700;
            padding: 0.8rem;
            text-align: right;
            font-weight: 500;
        }
        
        .data-table td {
            padding: 0.8rem;
            color: #fff;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
        }
        
        .data-table tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }
        
        .badge {
            display: inline-block;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
        }
        
        .badge-success {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }
        
        .badge-warning {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
            border: 1px solid #ffc107;
        }
        
        .badge-danger {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }
        
        .btn-sm {
            padding: 0.3rem 0.8rem;
            font-size: 0.8rem;
        }
        
        .media-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }
        
        .media-item {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .media-preview {
            height: 120px;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .media-preview i {
            font-size: 3rem;
            color: #ffd700;
        }
        
        .media-info {
            padding: 0.8rem;
            border-top: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .media-name {
            font-size: 0.8rem;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .media-size {
            font-size: 0.7rem;
            color: #aaa;
        }
    </style>
</head>
<body>
<!-- سایدبار -->
<%- include('sidebar', { activePage: 'webapp' }) %>

    <!-- محتوای اصلی -->
    <div class="main-content">
        <div class="header">
            <h1><i class="fas fa-globe"></i> <%= title %></h1>
        </div>

        <!-- آمار -->
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value"><%= stats.pages || 0 %></div>
                <div class="stat-label">تعداد صفحات</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.menus || 0 %></div>
                <div class="stat-label">آیتم‌های منو</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.media || 0 %></div>
                <div class="stat-label">فایل‌های رسانه</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.forms || 0 %></div>
                <div class="stat-label">فرم‌ها</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.users || 0 %></div>
                <div class="stat-label">کاربران</div>
            </div>
        </div>

        <!-- تب‌ها -->
        <div class="tabs">
            <div class="tab active" onclick="showTab('pages')">
                <i class="fas fa-file"></i> صفحات
            </div>
            <div class="tab" onclick="showTab('media')">
                <i class="fas fa-images"></i> کتابخانه مدیا
            </div>
            <div class="tab" onclick="showTab('menus')">
                <i class="fas fa-bars"></i> منوها
            </div>
            <div class="tab" onclick="showTab('forms')">
                <i class="fas fa-wpforms"></i> فرم‌ها
            </div>
            <div class="tab" onclick="showTab('settings')">
                <i class="fas fa-cog"></i> تنظیمات
            </div>
        </div>

        <!-- تب صفحات -->
        <div id="tab-pages" class="tab-content active">
            <div class="card">
                <h3><i class="fas fa-file"></i> مدیریت صفحات</h3>
                <button class="btn btn-sm" onclick="createPage()" style="margin-bottom: 1rem;">
                    <i class="fas fa-plus"></i> صفحه جدید
                </button>
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>عنوان</th>
                                <th>آدرس (slug)</th>
                                <th>زبان‌ها</th>
                                <th>وضعیت</th>
                                <th>صفحه اصلی</th>
                                <th>بازدید</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody id="pages-list">
                            <tr><td colspan="7" style="text-align:center;">در حال بارگذاری...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- تب مدیا -->
        <div id="tab-media" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-images"></i> کتابخانه مدیا</h3>
                <form id="upload-form" enctype="multipart/form-data">
                    <input type="file" id="file-input" name="file" style="display: none;" onchange="uploadFile()">
                    <button class="btn btn-sm" type="button" onclick="document.getElementById('file-input').click()">
                        <i class="fas fa-upload"></i> آپلود فایل جدید
                    </button>
                </form>
                <div class="media-grid" id="media-list">
                    <div style="text-align:center; padding:2rem;">در حال بارگذاری...</div>
                </div>
            </div>
        </div>

        <!-- تب منوها -->
        <div id="tab-menus" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-bars"></i> مدیریت منوها</h3>
                <button class="btn btn-sm" onclick="createMenu()" style="margin-bottom: 1rem;">
                    <i class="fas fa-plus"></i> آیتم منوی جدید
                </button>
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>عنوان</th>
                                <th>مکان</th>
                                <th>لینک</th>
                                <th>ترتیب</th>
                                <th>وضعیت</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody id="menus-list">
                            <tr><td colspan="6" style="text-align:center;">در حال بارگذاری...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- تب فرم‌ها -->
        <div id="tab-forms" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-wpforms"></i> مدیریت فرم‌ها</h3>
                <button class="btn btn-sm" onclick="createForm()" style="margin-bottom: 1rem;">
                    <i class="fas fa-plus"></i> فرم جدید
                </button>
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>نام فرم</th>
                                <th>تعداد ورودی</th>
                                <th>وضعیت</th>
                                <th>ایمیل گیرنده</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody id="forms-list">
                            <tr><td colspan="5" style="text-align:center;">در حال بارگذاری...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- تب تنظیمات -->
        <div id="tab-settings" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-cog"></i> تنظیمات وب‌اپ</h3>
                <div id="settings-form">
                    <p style="color:#aaa; text-align:center;">در حال بارگذاری...</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============= مدیریت تب‌ها =============
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + tabName).classList.add('active');
            event.target.classList.add('active');
            
            // بارگذاری داده‌های هر تب
            if (tabName === 'pages') loadPages();
            if (tabName === 'media') loadMedia();
            if (tabName === 'menus') loadMenus();
            if (tabName === 'forms') loadForms();
            if (tabName === 'settings') loadSettings();
        }

        // ============= توابع کمکی =============
        function showToast(message, type = 'success') {
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast';
                document.body.appendChild(toast);
            }
            toast.className = 'toast ' + type;
            toast.textContent = message;
            toast.style.display = 'block';
            setTimeout(() => toast.style.display = 'none', 2000);
        }

        // ============= مدیریت صفحات =============
        function loadPages() {
            fetch('/pprofessor/api/webapp/pages')
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        let html = '';
                        result.data.forEach(page => {
                            html += `<tr>
                                <td>${page.title_fa || 'بدون عنوان'}</td>
                                <td><code>${page.slug || '-'}</code></td>
                                <td>
                                    ${page.title_fa ? '🇮🇷' : ''} 
                                    ${page.title_en ? '🇬🇧' : ''} 
                                    ${page.title_ar ? '🇸🇦' : ''}
                                </td>
                                <td><span class="badge ${page.isActive ? 'badge-success' : 'badge-danger'}">${page.isActive ? 'فعال' : 'غیرفعال'}</span></td>
                                <td>${page.isHomepage ? '🏠 بله' : 'خیر'}</td>
                                <td>${page.viewCount || 0}</td>
                                <td>
                                    <button class="btn btn-sm" onclick="editPage(${page.id})"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" onclick="deletePage(${page.id})"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>`;
                        });
                        document.getElementById('pages-list').innerHTML = html;
                    }
                });
        }

        // ============= مدیریت مدیا =============
        function loadMedia() {
            fetch('/pprofessor/api/webapp/media')
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        let html = '';
                        result.data.forEach(media => {
                            html += `<div class="media-item">
                                <div class="media-preview">
                                    ${media.type === 'image' ? 
                                        `<img src="${media.url}" style="max-width:100%; max-height:100%;">` : 
                                        `<i class="fas fa-file-${media.type}"></i>`}
                                </div>
                                <div class="media-info">
                                    <div class="media-name">${media.originalName || media.filename}</div>
                                    <div class="media-size">${(media.size/1024).toFixed(1)} KB</div>
                                    <div style="margin-top:0.5rem;">
                                        <button class="btn btn-sm" onclick="copyMediaUrl('${media.url}')"><i class="fas fa-copy"></i></button>
                                        <button class="btn btn-sm btn-danger" onclick="deleteMedia(${media.id})"><i class="fas fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>`;
                        });
                        document.getElementById('media-list').innerHTML = html || '<div style="text-align:center;">فایلی یافت نشد</div>';
                    }
                });
        }

        function uploadFile() {
            const file = document.getElementById('file-input').files[0];
            if (!file) return;
            
            const formData = new FormData();
            formData.append('file', file);
            
            fetch('/pprofessor/api/webapp/media/upload', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    showToast('فایل با موفقیت آپلود شد');
                    loadMedia();
                } else {
                    showToast('خطا: ' + result.error, 'error');
                }
            });
        }

        function deleteMedia(id) {
            if (confirm('آیا از حذف این فایل اطمینان دارید؟')) {
                fetch('/pprofessor/api/webapp/media/' + id, { method: 'DELETE' })
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        showToast('فایل حذف شد');
                        loadMedia();
                    }
                });
            }
        }

        function copyMediaUrl(url) {
            navigator.clipboard.writeText(url);
            showToast('آدرس کپی شد');
        }

        // ============= مدیریت منوها =============
        function loadMenus() {
            fetch('/pprofessor/api/webapp/menus')
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        let html = '';
                        result.data.forEach(menu => {
                            html += `<tr>
                                <td>${menu.name_fa || '-'}</td>
                                <td>${menu.location === 'header' ? 'سربرگ' : menu.location === 'footer' ? 'پاورقی' : 'کناری'}</td>
                                <td>${menu.url || (menu.page ? '/' + menu.page.slug : '-')}</td>
                                <td>${menu.order || 0}</td>
                                <td><span class="badge ${menu.isActive ? 'badge-success' : 'badge-danger'}">${menu.isActive ? 'فعال' : 'غیرفعال'}</span></td>
                                <td>
                                    <button class="btn btn-sm" onclick="editMenu(${menu.id})"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteMenu(${menu.id})"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>`;
                        });
                        document.getElementById('menus-list').innerHTML = html;
                    }
                });
        }

        // ============= مدیریت فرم‌ها =============
        function loadForms() {
            fetch('/pprofessor/api/webapp/forms')
                .then(res => res.json())
                .then(result => {
                    if (result.success) {
                        let html = '';
                        result.data.forEach(form => {
                            html += `<tr>
                                <td>${form.name_fa || '-'}</td>
                                <td>${form.entries ? form.entries.length : 0}</td>
                                <td><span class="badge ${form.isActive ? 'badge-success' : 'badge-danger'}">${form.isActive ? 'فعال' : 'غیرفعال'}</span></td>
                                <td>${form.recipientEmail || '-'}</td>
                                <td>
                                    <button class="btn btn-sm" onclick="viewFormEntries(${form.id})"><i class="fas fa-list"></i></button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteForm(${form.id})"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>`;
                        });
                        document.getElementById('forms-list').innerHTML = html;
                    }
                });
        }

        // ============= مدیریت تنظیمات =============
        function loadSettings() {
            // اینجا بعداً تکمیل می‌شود
            document.getElementById('settings-form').innerHTML = '<p style="color:#aaa; text-align:center;">در حال توسعه...</p>';
        }

        // بارگذاری اولیه
        loadPages();
    </script>
</body>
</html>