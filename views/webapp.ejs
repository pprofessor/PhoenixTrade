            function viewFormEntries(formId) { showToast('در حال توسعه'); }
            function deleteForm(id) {
                if (confirm('آیا از حذف این فرم اطمینان دارید؟')) {
                    fetch(`/pprofessor/api/webapp/forms/${id}`, { method: 'DELETE' })
                        .then(res => { if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`); return res.json(); })
                        .then(result => { if (result.success) { showToast('فرم حذف شد'); loadForms(); } })
                        .catch(error => { console.error('Error:', error); showToast('خطا در حذف فرم', 'error'); });
                }
            }

            // ============= مدیریت کاربران =============
            function loadUsers() {
                fetch('/pprofessor/api/webapp/users')
                    .then(res => { if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`); return res.json(); })
                    .then(result => {
