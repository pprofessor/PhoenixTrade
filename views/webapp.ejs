                                <td>${new Date(form.createdAt).toLocaleDateString('fa-IR')}</td>
                                <td><button class="btn-icon" onclick="viewFormEntries(${form.id})"><i class="fas fa-list"></i></button>
                                <button class="btn-icon danger" onclick="deleteForm(${form.id})"><i class="fas fa-trash"></i></button></td>
                            </tr>`;
                            });
                            document.getElementById('forms-list').innerHTML = html;
                        }
                    })
                    .catch(error => { console.error('Error:', error); document.getElementById('forms-list').innerHTML = '<tr><td colspan="6" style="text-align:center; color:#dc3545;">خطا در بارگذاری فرم‌ها</td></tr>'; });
