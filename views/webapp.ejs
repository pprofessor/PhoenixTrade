                                <td><span class="badge ${user.isActive ? 'badge-success' : 'badge-danger'}" onclick="toggleUserStatus(${user.id})">${user.isActive ? 'فعال' : 'غیرفعال'}</span></td>
                                <td>${new Date(user.createdAt).toLocaleDateString('fa-IR')}</td>
                                <td><button class="btn-icon"><i class="fas fa-eye"></i></button></td>
