<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - PhoenixTrade
    </title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* استایل‌های اختصاصی صفحه بروکرها */
        .rating-stars {
            color: #ffd700;
            font-size: 1.1rem;
            display: inline-block;
            margin-left: 5px;
        }

        .regulator-badge {
            display: inline-block;
            background: rgba(255, 215, 0, 0.1);
            border: 1px solid #ffd700;
            color: #ffd700;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 0.8rem;
            margin: 2px;
        }

        .status-badge {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .status-active {
            background: rgba(40, 167, 69, 0.15);
            color: #28a745;
            border: 1px solid #28a745;
        }

        .status-inactive {
            background: rgba(220, 53, 69, 0.15);
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .featured-badge {
            background: #ffd700;
            color: #0a2f1f;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 0.75rem;
            display: inline-block;
        }

        /* تنظیمات جدول */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            background: rgba(255, 215, 0, 0.1);
            color: #ffd700;
            padding: 12px;
            text-align: right;
            font-weight: 500;
        }

        .data-table td {
            padding: 12px;
            color: #fff;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
        }

        .data-table tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        /* دکمه‌ها */
        .btn-icon {
            padding: 5px 10px;
            border-radius: 5px;
            background: transparent;
            border: 1px solid rgba(255, 215, 0, 0.3);
            color: #ffd700;
            cursor: pointer;
            margin: 0 3px;
        }

        .btn-icon:hover {
            background: #ffd700;
            color: #0a2f1f;
        }

        .btn-icon.danger:hover {
            background: #dc3545;
            color: white;
            border-color: #dc3545;
        }

        /* مودال */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #1a2f2a;
            border-radius: 15px;
            padding: 30px;
            max-width: 700px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            border: 1px solid #ffd700;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            color: #ffd700;
        }

        .modal-close {
            cursor: pointer;
            font-size: 1.5rem;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            color: #ffd700;
            margin-bottom: 5px;
        }

        .form-control {
            width: 100%;
            padding: 8px 12px;
            border-radius: 5px;
            border: 1px solid rgba(255, 215, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            color: #fff;
        }

        .form-control:focus {
            outline: none;
            border-color: #ffd700;
        }

        .btn {
            padding: 8px 20px;
            border-radius: 5px;
            border: none;
            background: linear-gradient(135deg, #ffd700, #b8860b);
            color: #0a2f1f;
            cursor: pointer;
            font-weight: bold;
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545, #a71d2a);
            color: white;
        }

        code {
            background: rgba(0, 0, 0, 0.3);
            padding: 2px 5px;
            border-radius: 3px;
            color: #ffd700;
        }
    </style>
</head>

<body>
    <!-- سایدبار -->
    <%- include('../sidebar', { activePage: 'brokers' }) %>

        <div class="main-content">
            <div class="header">
                <h1><i class="fas fa-building"></i>
                    <%= title %>
                </h1>
            </div>

            <!-- دکمه ایجاد بروکر جدید -->
            <div style="margin-bottom: 20px;">
                <button class="btn" onclick="showBrokerModal()">
                    <i class="fas fa-plus"></i> بروکر جدید
                </button>
            </div>

            <!-- جدول بروکرها -->
            <div class="table-container" style="overflow-x: auto;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>نام بروکر</th>
                            <th>slug</th>
                            <th>سال تأسیس</th>
                            <th>امتیاز</th>
                            <th>کاربران</th>
                            <th>رگوله‌ها</th>
                            <th>ویژه</th>
                            <th>وضعیت</th>
                            <th>ترتیب</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody id="brokers-list">
                        <tr>
                            <td colspan="10" style="text-align:center;">در حال بارگذاری...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- مودال ایجاد/ویرایش بروکر -->
        <div class="modal" id="broker-modal">
            <div class="modal-content" style="max-width: 700px;">
                <div class="modal-header">
                    <span id="modal-title">ایجاد بروکر جدید</span>
                    <span class="modal-close" onclick="closeModal()">&times;</span>
                </div>

                <form id="broker-form" onsubmit="event.preventDefault(); saveBroker();">
                    <input type="hidden" id="broker-id">

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <!-- ستون راست -->
                        <div>
                            <div class="form-group">
                                <label>نام بروکر</label>
                                <input type="text" id="broker-name" class="form-control" required>
                            </div>

                            <div class="form-group">
                                <label>لوگوی بروکر</label>
                                <div style="display: flex; gap: 10px; align-items: center;">
                                    <input type="file" id="broker-logo" accept="image/*" style="display: none;"
                                        onchange="previewLogo()">
                                    <button type="button" class="btn"
                                        onclick="document.getElementById('broker-logo').click()">
                                        <i class="fas fa-upload"></i> انتخاب لوگو
                                    </button>
                                    <img id="logo-preview" src=""
                                        style="width: 50px; height: 50px; border-radius: 10px; display: none;">
                                    <input type="hidden" id="broker-logo-url">
                                </div>
                                <small style="color:#aaa;">تصویر با فرمت PNG یا JPG، حداکثر ۵۰۰KB</small>
                            </div>

                            <div class="form-group">
                                <label>slug (آدرس یکتا)</label>
                                <input type="text" id="broker-slug" class="form-control" required>
                                <small style="color:#aaa;">مثال: tiomarkets</small>
                            </div>

                            <div class="form-group">
                                <label>سال تأسیس</label>
                                <input type="number" id="broker-founded" class="form-control" min="1900" max="2026">
                            </div>

                            <div class="form-group">
                                <label>تعداد کاربران</label>
                                <input type="text" id="broker-users" class="form-control" placeholder="مثلاً: +۵۰۰٬۰۰۰">
                            </div>

                            <div class="form-group">
                                <label>اسپرد</label>
                                <input type="text" id="broker-spread" class="form-control"
                                    placeholder="مثلاً: از ۰.۰ پیپ">
                            </div>
                        </div>

                        <!-- ستون چپ -->
                        <div>
                            <div class="form-group">
                                <label>اهرم</label>
                                <input type="text" id="broker-leverage" class="form-control"
                                    placeholder="مثلاً: ۱:۱۰۰۰">
                            </div>

                            <div class="form-group">
                                <label>حداقل واریز</label>
                                <input type="text" id="broker-minDeposit" class="form-control"
                                    placeholder="مثلاً: ۱۰۰ دلار">
                            </div>

                            <div class="form-group">
                                <label>لینک ثبت‌نام</label>
                                <input type="url" id="broker-registerLink" class="form-control">
                            </div>

                            <div class="form-group">
                                <label>امتیاز (۰ تا ۵)</label>
                                <input type="number" id="broker-rating" class="form-control" min="0" max="5" step="0.1"
                                    value="0">
                            </div>

                            <div class="form-group">
                                <label>ترتیب نمایش</label>
                                <input type="number" id="broker-order" class="form-control" value="0">
                            </div>
                        </div>
                    </div>

                    <!-- رگوله‌ها -->
                    <div class="form-group">
                        <label>رگوله‌ها</label>
                        <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px;">
                            <label style="color:white;"><input type="checkbox" value="FCA (UK)"> FCA (UK)</label>
                            <label style="color:white;"><input type="checkbox" value="CySEC (EU)"> CySEC (EU)</label>
                            <label style="color:white;"><input type="checkbox" value="ASIC (AU)"> ASIC (AU)</label>
                            <label style="color:white;"><input type="checkbox" value="SVG"> SVG</label>
                            <label style="color:white;"><input type="checkbox" value="FSA"> FSA</label>
                            <label style="color:white;"><input type="checkbox" value="BaFin"> BaFin</label>
                        </div>
                        <input type="text" id="broker-regulations" class="form-control"
                            placeholder="یا به صورت دستی وارد کنید (با کاما جدا)">
                    </div>

                    <!-- وضعیت‌ها -->
                    <div style="display: flex; gap: 20px; margin: 20px 0;">
                        <label style="color:white;">
                            <input type="checkbox" id="broker-isActive" checked> فعال
                        </label>
                        <label style="color:white;">
                            <input type="checkbox" id="broker-isFeatured"> بروکر ویژه
                        </label>
                    </div>

                    <div style="display: flex; gap: 10px; margin-top: 20px;">
                        <button type="submit" class="btn">ذخیره</button>
                        <button type="button" class="btn btn-danger" onclick="closeModal()">انصراف</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            // ============= بارگذاری لیست بروکرها =============
            function loadBrokers() {
                fetch('/pprofessor/api/brokers')
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            let html = '';
                            result.data.forEach(broker => {
                                const regulations = JSON.parse(broker.regulations || '[]');
                                const rating = parseFloat(broker.rating).toFixed(1);

                                // ساخت ستاره‌ها
                                let stars = '';
                                for (let i = 1; i <= 5; i++) {
                                    if (i <= Math.floor(broker.rating)) {
                                        stars += '★';
                                    } else {
                                        stars += '☆';
                                    }
                                }

                                html += `<tr>
                                <td>${broker.name}</td>
                                <td><code>${broker.slug}</code></td>
                                <td>${broker.foundedYear || '-'}</td>
                                <td>
                                    <span class="rating-stars">${stars}</span>
                                    <span style="color:#aaa;">(${rating})</span>
                                </td>
                                <td>${broker.usersCount || '۰'}</td>
                                <td>
                                    ${regulations.map(r => `<span class="regulator-badge">${r}</span>`).join(' ')}
                                </td>
                                <td>${broker.isFeatured ? '<span class="featured-badge">ویژه</span>' : '-'}</td>
                                <td>
                                    <span class="status-badge ${broker.isActive ? 'status-active' : 'status-inactive'}">
                                        ${broker.isActive ? 'فعال' : 'غیرفعال'}
                                    </span>
                                </td>
                                <td>${broker.order || 0}</td>
                                <td>
                                    <button class="btn-icon" onclick="editBroker(${broker.id})"><i class="fas fa-edit"></i></button>
                                    <button class="btn-icon danger" onclick="deleteBroker(${broker.id})"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>`;
                            });
                            document.getElementById('brokers-list').innerHTML = html;
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        document.getElementById('brokers-list').innerHTML = '<tr><td colspan="10" style="text-align:center; color:#dc3545;">خطا در بارگذاری</td></tr>';
                    });
            }

            // ============= نمایش مودال ایجاد بروکر =============
            function showBrokerModal() {
                document.getElementById('modal-title').textContent = 'ایجاد بروکر جدید';
                document.getElementById('broker-id').value = '';
                document.getElementById('broker-name').value = '';
                document.getElementById('broker-slug').value = '';
                document.getElementById('broker-founded').value = '';
                document.getElementById('broker-users').value = '';
                document.getElementById('broker-spread').value = '';
                document.getElementById('broker-leverage').value = '';
                document.getElementById('broker-minDeposit').value = '';
                document.getElementById('broker-registerLink').value = '';
                document.getElementById('broker-rating').value = '0';
                document.getElementById('broker-order').value = '0';
                document.getElementById('broker-isActive').checked = true;
                document.getElementById('broker-isFeatured').checked = false;

                // پاک کردن چک‌باکس‌های رگوله
                document.querySelectorAll('#broker-form input[type="checkbox"]').forEach(cb => {
                    if (!cb.id.includes('broker-is')) cb.checked = false;
                });
                document.getElementById('broker-regulations').value = '';

                document.getElementById('broker-modal').classList.add('active');
            }

            // ============= ویرایش بروکر =============
            function editBroker(id) {
                fetch(`/pprofessor/api/brokers/${id}`)
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            const broker = result.data;
                            document.getElementById('modal-title').textContent = 'ویرایش بروکر';
                            document.getElementById('broker-id').value = broker.id;
                            document.getElementById('broker-name').value = broker.name || '';
                            document.getElementById('broker-slug').value = broker.slug || '';

                            // نمایش لوگو اگر وجود دارد
                            if (broker.logo) {
                                document.getElementById('logo-preview').src = broker.logo;
                                document.getElementById('logo-preview').style.display = 'block';
                                document.getElementById('broker-logo-url').value = broker.logo;
                            } else {
                                document.getElementById('logo-preview').style.display = 'none';
                                document.getElementById('broker-logo-url').value = '';
                            }

                            document.getElementById('broker-founded').value = broker.foundedYear || '';
                            document.getElementById('broker-users').value = broker.usersCount || '';
                            document.getElementById('broker-spread').value = broker.spread || '';
                            document.getElementById('broker-leverage').value = broker.leverage || '';
                            document.getElementById('broker-minDeposit').value = broker.minDeposit || '';
                            document.getElementById('broker-registerLink').value = broker.registerLink || '';
                            document.getElementById('broker-rating').value = broker.rating || '0';
                            document.getElementById('broker-order').value = broker.order || '0';
                            document.getElementById('broker-isActive').checked = broker.isActive;
                            document.getElementById('broker-isFeatured').checked = broker.isFeatured;

                            // تنظیم رگوله‌ها
                            const regulations = JSON.parse(broker.regulations || '[]');
                            document.querySelectorAll('#broker-form input[type="checkbox"]').forEach(cb => {
                                if (regulations.includes(cb.value)) {
                                    cb.checked = true;
                                }
                            });
                            document.getElementById('broker-regulations').value = regulations.join(', ');

                            document.getElementById('broker-modal').classList.add('active');
                        }
                    });
            }

            // ============= ذخیره بروکر =============
            function saveBroker() {
                // جمع‌آوری رگوله‌ها
                const regulations = [];
                document.querySelectorAll('#broker-form input[type="checkbox"]').forEach(cb => {
                    if (cb.checked && !cb.id.includes('broker-is')) {
                        regulations.push(cb.value);
                    }
                });

                // اضافه کردن رگوله‌های دستی
                const manualRegs = document.getElementById('broker-regulations').value.split(',').map(s => s.trim()).filter(s => s);
                regulations.push(...manualRegs);

                const data = {
                    name: document.getElementById('broker-name').value,
                    slug: document.getElementById('broker-slug').value,
                    logo: document.getElementById('broker-logo-url').value, // این خط اضافه شد
                    foundedYear: document.getElementById('broker-founded').value || null,
                    usersCount: document.getElementById('broker-users').value,
                    spread: document.getElementById('broker-spread').value,
                    leverage: document.getElementById('broker-leverage').value,
                    minDeposit: document.getElementById('broker-minDeposit').value,
                    registerLink: document.getElementById('broker-registerLink').value,
                    rating: parseFloat(document.getElementById('broker-rating').value) || 0,
                    order: parseInt(document.getElementById('broker-order').value) || 0,
                    regulations: regulations,
                    isActive: document.getElementById('broker-isActive').checked,
                    isFeatured: document.getElementById('broker-isFeatured').checked
                };

                const id = document.getElementById('broker-id').value;
                const url = id ? `/pprofessor/api/brokers/${id}` : '/pprofessor/api/brokers';
                const method = id ? 'PUT' : 'POST';

                fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            showToast(id ? 'بروکر ویرایش شد' : 'بروکر ایجاد شد');
                            closeModal();
                            loadBrokers();
                        } else {
                            showToast('خطا: ' + result.error, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('خطا در ارتباط با سرور', 'error');
                    });
            }

            // ============= پیش‌نمایش لوگو =============
            function previewLogo() {
                const file = document.getElementById('broker-logo').files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        document.getElementById('logo-preview').src = e.target.result;
                        document.getElementById('logo-preview').style.display = 'block';
                    };
                    reader.readAsDataURL(file);

                    // آپلود خودکار لوگو
                    uploadLogo(file);
                }
            }

            // ============= آپلود لوگو =============
            function uploadLogo(file) {
                const formData = new FormData();
                formData.append('logo', file);

                fetch('/pprofessor/api/upload/logo', {
                    method: 'POST',
                    body: formData
                })
                    .then(res => res.json())
                    .then(result => {
                        if (result.success) {
                            document.getElementById('broker-logo-url').value = result.url;
                            showToast('لوگو با موفقیت آپلود شد');
                        } else {
                            showToast('خطا در آپلود لوگو', 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('خطا در آپلود لوگو', 'error');
                    });
            }

            // ============= حذف بروکر =============
            function deleteBroker(id) {
                if (confirm('آیا از حذف این بروکر اطمینان دارید؟')) {
                    fetch(`/pprofessor/api/brokers/${id}`, { method: 'DELETE' })
                        .then(res => res.json())
                        .then(result => {
                            if (result.success) {
                                showToast('بروکر حذف شد');
                                loadBrokers();
                            } else {
                                showToast('خطا: ' + result.error, 'error');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            showToast('خطا در ارتباط با سرور', 'error');
                        });
                }
            }

            // ============= بستن مودال =============
            function closeModal() {
                document.getElementById('broker-modal').classList.remove('active');
            }

            // ============= نمایش پیام =============
            function showToast(message, type = 'success') {
                // حذف toast قبلی اگر وجود دارد
                const oldToast = document.getElementById('toast');
                if (oldToast) oldToast.remove();

                const toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast ' + type;
                toast.textContent = message;
                toast.style.cssText = `
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                padding: 15px 30px;
                border-radius: 10px;
                color: white;
                font-weight: bold;
                z-index: 9999;
                background: ${type === 'success' ? 'rgba(40, 167, 69, 0.9)' : 'rgba(220, 53, 69, 0.9)'};
                backdrop-filter: blur(10px);
                border: 1px solid ${type === 'success' ? '#28a745' : '#dc3545'};
            `;
                document.body.appendChild(toast);

                setTimeout(() => toast.remove(), 3000);
            }

            // ============= بارگذاری اولیه =============
            document.addEventListener('DOMContentLoaded', loadBrokers);
        </script>
</body>

</html>