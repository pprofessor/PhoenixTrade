<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* ===== استایل‌های اختصاصی صفحه دیتابیس ===== */
        
        /* تب‌ها */
        .tabs {
            display: flex;
            gap: 0.8rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }
        
        .tab {
            padding: 0.6rem 1.8rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 25px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255, 215, 0, 0.2);
            font-size: 0.95rem;
        }
        
        .tab:hover {
            border-color: #ffd700;
        }
        
        .tab.active {
            background: #ffd700;
            color: #0a2f1f;
            font-weight: bold;
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        /* ===== کارت‌ها ===== */
        .card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .card h3 {
            color: #ffd700;
            margin-bottom: 1.2rem;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
        
        /* ===== آمار دیتابیس ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        
        .stat-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 1.2rem;
            text-align: center;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .stat-value {
            color: #ffd700;
            font-size: 1.8rem;
            font-weight: bold;
        }
        
        .stat-label {
            color: #aaa;
            margin-top: 0.3rem;
            font-size: 0.9rem;
        }
        
        /* ===== ترمینال ===== */
        .terminal {
            background: #1e1e1e;
            border-radius: 12px;
            overflow: hidden;
            font-family: 'Courier New', monospace;
            border: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .terminal-header {
            background: #2d2d2d;
            padding: 0.6rem 1rem;
            color: #ffd700;
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .terminal-body {
            padding: 1rem;
            min-height: 150px;
            max-height: 250px;
            overflow-y: auto;
            background: #1e1e1e;
            color: #0f0;
            font-size: 0.9rem;
        }
        
        .terminal-input {
            display: flex;
            padding: 0.6rem 1rem;
            background: #2d2d2d;
            border-top: 1px solid rgba(255, 215, 0, 0.2);
        }
        
        .terminal-prompt {
            color: #ffd700;
            margin-left: 0.6rem;
        }
        
        .terminal-input input {
            flex: 1;
            background: transparent;
            border: none;
            color: #fff;
            font-family: 'Courier New', monospace;
            outline: none;
            font-size: 0.9rem;
        }
        
        .terminal-output {
            color: #0f0;
            margin: 0.2rem 0;
        }
        
        .terminal-error {
            color: #f00;
        }
        
        /* ===== دستورات پرکاربرد ===== */
        .commands-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 0.8rem;
            margin-top: 1rem;
        }
        
        .command-item {
            background: rgba(255, 255, 255, 0.03);
            padding: 1rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255, 215, 0, 0.1);
        }
        
        .command-item:hover {
            border-color: #ffd700;
            background: rgba(255, 215, 0, 0.05);
        }
        
        .command-title {
            color: #ffd700;
            font-weight: bold;
            font-size: 0.9rem;
            margin-bottom: 0.3rem;
        }
        
        .command-desc {
            color: #aaa;
            font-size: 0.8rem;
        }
        
        /* ===== گرید داده‌ها ===== */
        .data-grid {
            overflow-x: auto;
            border-radius: 12px;
            background: rgba(0, 0, 0, 0.2);
            padding: 0.5rem;
        }
        
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }
        
        .data-table th {
            background: rgba(255, 215, 0, 0.15);
            color: #ffd700;
            padding: 0.8rem;
            text-align: right;
            font-weight: 500;
        }
        
        .data-table td {
            padding: 0.8rem;
            color: #fff;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
        }
        
        .data-table tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }
        
        /* ===== جستجو ===== */
        .search-box {
            display: flex;
            gap: 0.8rem;
            margin: 1rem 0;
            flex-wrap: wrap;
        }
        
        .search-box input,
        .search-box select {
            padding: 0.6rem 1rem;
            border-radius: 20px;
            border: 1px solid rgba(255, 215, 0, 0.2);
            background: rgba(0, 0, 0, 0.3);
            color: #fff;
            flex: 1;
            min-width: 150px;
        }
        
        .search-box input:focus,
        .search-box select:focus {
            outline: none;
            border-color: #ffd700;
        }
        
        /* ===== انتخابگر جدول ===== */
        #table-select {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 215, 0, 0.2);
            color: #fff;
            padding: 0.6rem 1.2rem;
            border-radius: 20px;
            margin-bottom: 1rem;
            min-width: 200px;
        }
        
        #table-select:focus {
            outline: none;
            border-color: #ffd700;
        }
    </style>
</head>
<body>
    <!-- سایدبار -->
    <%- include('sidebar', { activePage: 'database' }) %>

    <!-- محتوای اصلی -->
    <div class="main-content">
        <div class="header">
            <h1><i class="fas fa-server"></i> <%= title %></h1>
        </div>

        <!-- آمار دیتابیس (داده‌های واقعی از سرور) -->
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value"><%= stats.totalTables || 8 %></div>
                <div class="stat-label">تعداد جداول</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.totalRecords || 124 %></div>
                <div class="stat-label">کل رکوردها</div>
            </div>
            <div class="stat-item">
                <div class="stat-value"><%= stats.dbSize || '۳.۲' %></div>
                <div class="stat-label">حجم (مگابایت)</div>
            </div>
        </div>

        <!-- تب‌ها -->
        <div class="tabs">
            <div class="tab active" onclick="showTab('terminal')">
                <i class="fas fa-terminal"></i> ترمینال SQL
            </div>
            <div class="tab" onclick="showTab('data')">
                <i class="fas fa-table"></i> مدیریت داده‌ها
            </div>
            <div class="tab" onclick="showTab('schema')">
                <i class="fas fa-diagram-project"></i> ساختار جداول
            </div>
        </div>

        <!-- تب 1: ترمینال SQL -->
        <div id="tab-terminal" class="tab-content active">
            <div class="card">
                <h3><i class="fas fa-terminal"></i> ترمینال SQL</h3>
                <div class="terminal">
                    <div class="terminal-header">
                        <span>SQLite Terminal</span>
                        <span>متصل</span>
                    </div>
                    <div class="terminal-body" id="terminal-output">
                        <% if (terminalHistory && terminalHistory.length > 0) { %>
                            <% terminalHistory.forEach(line => { %>
                                <div class="terminal-output"><%= line %></div>
                            <% }); %>
                        <% } else { %>
                            <div class="terminal-output">SQLite version 3.45.1</div>
                            <div class="terminal-output">Enter ".help" for usage hints.</div>
                            <div class="terminal-output">sqlite></div>
                        <% } %>
                    </div>
                    <div class="terminal-input">
                        <span class="terminal-prompt">sqlite></span>
                        <input type="text" id="sql-input" placeholder="دستور SQL را وارد کنید..." 
                               onkeypress="handleSqlKeyPress(event)" 
                               value="<%= lastCommand || '' %>">
                    </div>
                </div>

                <h3 style="margin-top: 1.5rem;">دستورات پرکاربرد</h3>
                <div class="commands-grid">
                    <% if (commonCommands && commonCommands.length > 0) { %>
                        <% commonCommands.forEach(cmd => { %>
                            <div class="command-item" onclick='insertSqlCommand("<%= cmd.command %>")'>
                                <div class="command-title"><%= cmd.title %></div>
                                <div class="command-desc"><%= cmd.description %></div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- تب 2: مدیریت داده‌ها -->
        <div id="tab-data" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-table"></i> مدیریت داده‌ها</h3>
                
                <!-- انتخاب جدول -->
                <select id="table-select" onchange="loadTableData()">
                    <option value="">-- انتخاب جدول --</option>
                    <% if (tables && tables.length > 0) { %>
                        <% tables.forEach(table => { %>
                            <option value="<%= table.name %>" <%= table.name === selectedTable ? 'selected' : '' %>>
                                <%= table.name %> (<%= table.recordCount %> رکورد)
                            </option>
                        <% }); %>
                    <% } %>
                </select>

                <!-- جستجو -->
                <div class="search-box">
                    <input type="text" id="search-input" placeholder="جستجو...">
                    <select id="search-field">
                        <option value="all">همه فیلدها</option>
                        <% if (currentColumns && currentColumns.length > 0) { %>
                            <% currentColumns.forEach(col => { %>
                                <option value="<%= col %>"><%= col %></option>
                            <% }); %>
                        <% } %>
                    </select>
                    <button class="btn btn-sm" onclick="searchData()">
                        <i class="fas fa-search"></i> جستجو
                    </button>
                </div>

                <!-- جدول داده‌ها -->
                <div class="data-grid">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <% if (currentColumns && currentColumns.length > 0) { %>
                                    <% currentColumns.forEach(col => { %>
                                        <th><%= col %></th>
                                    <% }); %>
                                    <th>عملیات</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (currentData && currentData.length > 0) { %>
                                <% currentData.forEach(row => { %>
                                    <tr>
                                        <% currentColumns.forEach(col => { %>
                                            <td><%= row[col] || '-' %></td>
                                        <% }); %>
                                        <td>
                                            <button class="btn btn-sm btn-success" onclick="editRow(<%= row.id %>)">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" onclick="deleteRow(<%= row.id %>)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="100%" style="text-align: center; color: #aaa;">
                                        داده‌ای برای نمایش وجود ندارد
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- تب 3: ساختار جداول -->
        <div id="tab-schema" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-diagram-project"></i> ساختار جداول</h3>
                <div class="commands-grid">
                    <% if (tableSchemas && tableSchemas.length > 0) { %>
                        <% tableSchemas.forEach(schema => { %>
                            <div class="command-item">
                                <div class="command-title"><%= schema.name %></div>
                                <div class="command-desc"><%= schema.columns.join('، ') %></div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============= متغیرهای سراسری =============
        let currentTable = '<%= selectedTable || "" %>';
        
        // ============= مدیریت تب‌ها =============
        function showTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.getElementById('tab-' + tabName).classList.add('active');
            event.target.classList.add('active');
        }

        // ============= ترمینال SQL =============
        function insertSqlCommand(cmd) {
            document.getElementById('sql-input').value = cmd;
        }

        function handleSqlKeyPress(event) {
            if (event.key === 'Enter') {
                const cmd = document.getElementById('sql-input').value;
                executeSql(cmd);
            }
        }

        function executeSql(cmd) {
            fetch('/pprofessor/api/database/query', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ query: cmd })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast('دستور با موفقیت اجرا شد');
                    // به‌روزرسانی خروجی ترمینال
                    const output = document.getElementById('terminal-output');
                    output.innerHTML += `<div class="terminal-output">sqlite> ${cmd}</div>`;
                    data.results.forEach(line => {
                        output.innerHTML += `<div class="terminal-output">${line}</div>`;
                    });
                    output.innerHTML += `<div class="terminal-output">sqlite></div>`;
                    output.scrollTop = output.scrollHeight;
                } else {
                    showToast('خطا: ' + data.error, 'error');
                }
            })
            .catch(() => showToast('خطا در ارتباط با سرور', 'error'));
            
            document.getElementById('sql-input').value = '';
        }

        // ============= مدیریت داده‌ها =============
        function loadTableData() {
            const table = document.getElementById('table-select').value;
            if (!table) return;
            
            window.location.href = '/pprofessor/database?table=' + table;
        }

        function searchData() {
            const searchTerm = document.getElementById('search-input').value;
            const searchField = document.getElementById('search-field').value;
            
            fetch('/pprofessor/api/database/search', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    table: currentTable,
                    field: searchField,
                    term: searchTerm
                })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // به‌روزرسانی جدول با داده‌های جدید
                    location.reload();
                }
            });
        }

        function editRow(id) {
            window.location.href = '/pprofessor/database/edit/' + currentTable + '/' + id;
        }

        function deleteRow(id) {
            if (confirm('آیا از حذف این رکورد اطمینان دارید؟')) {
                fetch('/pprofessor/api/database/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        table: currentTable,
                        id: id
                    })
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showToast('رکورد با موفقیت حذف شد');
                        location.reload();
                    } else {
                        showToast('خطا: ' + data.error, 'error');
                    }
                });
            }
        }

        // ============= تابع نمایش پیام =============
        function showToast(message, type = 'success') {
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast';
                document.body.appendChild(toast);
            }
            
            toast.className = 'toast ' + type;
            toast.textContent = message;
            toast.style.display = 'block';
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 2000);
        }
    </script>
</body>
</html>