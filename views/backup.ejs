<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* ===== استایل‌های اختصاصی صفحه بکاپ ===== */
        
        /* کارت‌های تنظیمات بکاپ */
        .settings-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 1.8rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 215, 0, 0.3);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        }
        
        .settings-card h3 {
            color: #ffd700;
            margin-bottom: 1.5rem;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }
        
        /* فرم‌ها */
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            color: #fff;
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }
        
        .form-group select,
        .form-group input[type="text"] {
            width: 100%;
            padding: 0.8rem 1rem;
            border-radius: 12px;
            border: 1px solid rgba(255, 215, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            color: #fff;
            font-size: 0.95rem;
            font-family: 'Samim', sans-serif;
        }
        
        .form-group select:focus,
        .form-group input[type="text"]:focus {
            outline: none;
            border-color: #ffd700;
        }
        
        .form-group option {
            background: #1a4a2c;
        }
        
        /* گرید چک‌باکس‌ها */
        .checkbox-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
            background: rgba(0, 0, 0, 0.2);
            padding: 1.5rem;
            border-radius: 16px;
        }
        
        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #fff;
        }
        
        .checkbox-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #ffd700;
            cursor: pointer;
        }
        
        .checkbox-item label {
            cursor: pointer;
            font-size: 0.95rem;
        }
        
        /* رادیو گروه */
        .radio-group {
            display: flex;
            gap: 2rem;
            color: #fff;
            background: rgba(0, 0, 0, 0.2);
            padding: 1rem 1.5rem;
            border-radius: 12px;
        }
        
        .radio-group label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
        }
        
        .radio-group input[type="radio"] {
            accent-color: #ffd700;
            width: 16px;
            height: 16px;
        }
        
        /* دکمه‌ها */
        .btn-success {
            background: linear-gradient(135deg, #28a745, #1e7e34);
            color: #fff;
        }
        
        .btn-success:hover {
            background: linear-gradient(135deg, #1e7e34, #155d27);
        }
        
        /* جدول بکاپ‌ها */
        .table {
            width: 100%;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
            overflow: hidden;
            border-collapse: collapse;
        }
        
        .table th {
            background: rgba(255, 215, 0, 0.15);
            color: #ffd700;
            padding: 1rem;
            text-align: right;
            font-weight: 500;
            font-size: 0.95rem;
        }
        
        .table td {
            padding: 1rem;
            color: #fff;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
            font-size: 0.9rem;
        }
        
        .table tr:hover {
            background: rgba(255, 255, 255, 0.05);
        }
        
        /* لیست فایل‌ها */
        .file-list {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
            padding: 1rem;
        }
        
        .file-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem;
            border-bottom: 1px solid rgba(255, 215, 0, 0.1);
            transition: all 0.2s;
        }
        
        .file-item:hover {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
        }
        
        .file-item:last-child {
            border-bottom: none;
        }
        
        .file-info {
            color: #fff;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .file-info i {
            color: #ffd700;
            font-size: 1.2rem;
        }
        
        .file-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .file-size {
            color: #aaa;
            font-size: 0.85rem;
            background: rgba(0, 0, 0, 0.3);
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
        }
        
        /* پنل جزئیات */
        #file-details {
            margin-top: 2rem;
            animation: fadeIn 0.3s ease;
        }
        
        #file-details h4 {
            color: #ffd700;
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }
        
        #file-details ul {
            list-style: none;
            margin: 1rem 0;
        }
        
        #file-details li {
            margin-bottom: 0.5rem;
            color: #fff;
        }
        
        /* تب‌ها */
        .tabs {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }
        
        .tab {
            padding: 0.7rem 2rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 30px;
            color: #fff;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid rgba(255, 215, 0, 0.2);
            font-size: 0.95rem;
        }
        
        .tab:hover {
            border-color: #ffd700;
        }
        
        .tab.active {
            background: #ffd700;
            color: #0a2f1f;
            font-weight: bold;
        }
        
        .tab-content {
            display: none;
            animation: fadeIn 0.3s ease;
        }
        
        .tab-content.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <!-- سایدبار -->
    <%- include('sidebar', { activePage: 'backup' }) %>

    <!-- محتوای اصلی -->
    <div class="main-content">
        <div class="header">
            <h1><i class="fas fa-database"></i> <%= title %></h1>
        </div>

        <!-- تب‌ها -->
        <div class="tabs">
            <div class="tab active" onclick="showTab('settings')">
                <i class="fas fa-cog"></i> تنظیمات بکاپ
            </div>
            <div class="tab" onclick="showTab('list')">
                <i class="fas fa-list"></i> لیست بکاپ‌ها
            </div>
            <div class="tab" onclick="showTab('files')">
                <i class="fas fa-folder"></i> مدیریت فایل‌ها
            </div>
        </div>

        <!-- تب تنظیمات بکاپ -->
        <div id="tab-settings" class="tab-content active">
            <div class="settings-card">
                <h3><i class="fas fa-clock"></i> تنظیمات بکاپ‌گیری خودکار</h3>
                <div class="form-group">
                    <label>⏱️ دوره زمانی بکاپ‌گیری خودکار:</label>
                    <select>
                        <option value="1">هر یک ساعت</option>
                        <option value="2">هر 2 ساعت</option>
                        <option value="6">هر 6 ساعت</option>
                        <option value="12">هر 12 ساعت</option>
                        <option value="24" selected>هر 24 ساعت</option>
                        <option value="48">هر 2 روز</option>
                        <option value="120">هر 5 روز</option>
                        <option value="240">هر 10 روز</option>
                        <option value="360">هر 15 روز</option>
                        <option value="720">هر 30 روز</option>
                    </select>
                </div>

                <h3><i class="fas fa-layer-group"></i> بخش‌های مورد نظر برای بکاپ</h3>
                <div class="checkbox-grid">
                    <div class="checkbox-item">
                        <input type="checkbox" id="db" checked> <label for="db">دیتابیس (SQLite)</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="botMessages" checked> <label for="botMessages">پیام‌های ربات</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="webappPages" checked> <label for="webappPages">صفحات وب‌اپ</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="lessons" checked> <label for="lessons">درس‌ها</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="brokers"> <label for="brokers">بروکرها</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="events"> <label for="events">رویدادها</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="categories"> <label for="categories">دسته‌بندی‌ها</label>
                    </div>
                    <div class="checkbox-item">
                        <input type="checkbox" id="admins"> <label for="admins">مدیران</label>
                    </div>
                </div>

                <h3><i class="fas fa-folder"></i> محل ذخیره بکاپ</h3>
                <div class="radio-group">
                    <label>
                        <input type="radio" name="storage" value="server" checked> 📁 ذخیره در پوشه Backups روی سرور
                    </label>
                    <label>
                        <input type="radio" name="storage" value="download"> ⬇️ دانلود مستقیم روی سیستم کلاینت
                    </label>
                </div>

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button class="btn btn-success" onclick="startBackup()">
                        <i class="fas fa-play"></i> شروع بکاپ‌گیری دستی
                    </button>
                    <button class="btn" onclick="saveSettings()">
                        <i class="fas fa-save"></i> ذخیره تنظیمات
                    </button>
                </div>
            </div>
        </div>

        <!-- تب لیست بکاپ‌ها -->
        <div id="tab-list" class="tab-content">
            <div class="settings-card">
                <h3><i class="fas fa-history"></i> لیست بکاپ‌های گرفته شده</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th>تاریخ و ساعت</th>
                            <th>محل ذخیره</th>
                            <th>بخش‌ها</th>
                            <th>حجم</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>۱۴۰۴/۱۲/۰۸ - ۱۵:۳۰</td>
                            <td>/backups/auto_14041208_1530.zip</td>
                            <td>دیتابیس، ربات، وب‌اپ</td>
                            <td>۲.۴ مگابایت</td>
                            <td>
                                <button class="btn btn-sm" onclick="downloadFile('auto_14041208_1530.zip')"><i class="fas fa-download"></i></button>
                                <button class="btn btn-sm btn-danger" onclick="deleteFile('auto_14041208_1530.zip')"><i class="fas fa-trash"></i></button>
                                <button class="btn btn-sm" onclick="showFileDetails('auto_14041208_1530.zip')"><i class="fas fa-info-circle"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>۱۴۰۴/۱۲/۰۷ - ۰۸:۱۵</td>
                            <td>/backups/manual_14041207_0815.zip</td>
                            <td>دیتابیس، درس‌ها، بروکرها</td>
                            <td>۳.۱ مگابایت</td>
                            <td>
                                <button class="btn btn-sm"><i class="fas fa-download"></i></button>
                                <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                <button class="btn btn-sm"><i class="fas fa-info-circle"></i></button>
                            </td>
                        </tr>
                        <tr>
                            <td>۱۴۰۴/۱۲/۰۶ - ۲۲:۴۰</td>
                            <td>/backups/auto_14041206_2240.zip</td>
                            <td>دیتابیس، ربات</td>
                            <td>۱.۸ مگابایت</td>
                            <td>
                                <button class="btn btn-sm"><i class="fas fa-download"></i></button>
                                <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                                <button class="btn btn-sm"><i class="fas fa-info-circle"></i></button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- تب مدیریت فایل‌ها -->
        <div id="tab-files" class="tab-content">
            <div class="settings-card">
                <h3><i class="fas fa-folder-open"></i> پوشه Backups روی سرور</h3>
                <div class="file-list">
                    <div class="file-item">
                        <div class="file-info">
                            <i class="fas fa-file-archive"></i>
                            <span>auto_14041208_1530.zip</span>
                            <span class="file-size">۲.۴ مگابایت</span>
                        </div>
                        <div class="file-actions">
                            <button class="btn btn-sm" onclick="showFileDetails('auto_14041208_1530.zip')">
                                <i class="fas fa-info-circle"></i>
                            </button>
                            <button class="btn btn-sm" onclick="downloadFile('auto_14041208_1530.zip')">
                                <i class="fas fa-download"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteFile('auto_14041208_1530.zip')">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="file-item">
                        <div class="file-info">
                            <i class="fas fa-file-archive"></i>
                            <span>manual_14041207_0815.zip</span>
                            <span class="file-size">۳.۱ مگابایت</span>
                        </div>
                        <div class="file-actions">
                            <button class="btn btn-sm"><i class="fas fa-info-circle"></i></button>
                            <button class="btn btn-sm"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                    <div class="file-item">
                        <div class="file-info">
                            <i class="fas fa-file-archive"></i>
                            <span>auto_14041206_2240.zip</span>
                            <span class="file-size">۱.۸ مگابایت</span>
                        </div>
                        <div class="file-actions">
                            <button class="btn btn-sm"><i class="fas fa-info-circle"></i></button>
                            <button class="btn btn-sm"><i class="fas fa-download"></i></button>
                            <button class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>

                <!-- پنل جزئیات فایل -->
                <div id="file-details" style="display: none;">
                    <h4><i class="fas fa-info-circle"></i> جزئیات فایل: <span id="detail-filename"></span></h4>
                    <div style="background: rgba(0,0,0,0.3); padding: 1.5rem; border-radius: 16px;">
                        <p><strong style="color: #ffd700;">بخش‌های بکاپ گرفته شده:</strong></p>
                        <ul>
                            <li>✅ دیتابیس (SQLite) - ۱.۵ مگابایت</li>
                            <li>✅ پیام‌های ربات - ۰.۳ مگابایت</li>
                            <li>✅ صفحات وب‌اپ - ۰.۲ مگابایت</li>
                            <li>✅ درس‌ها - ۰.۴ مگابایت</li>
                        </ul>
                        <p><strong style="color: #ffd700;">مسیر ذخیره:</strong> <span style="color: #fff;" id="detail-path"></span></p>
                        <p><strong style="color: #ffd700;">تاریخ ایجاد:</strong> <span style="color: #fff;" id="detail-date"></span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============= مدیریت تب‌ها =============
        function showTab(tabName) {
            // مخفی کردن همه تب‌ها
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // فعال کردن تب انتخاب شده
            document.getElementById('tab-' + tabName).classList.add('active');
            event.target.classList.add('active');
        }

        // ============= توابع بکاپ =============
        function startBackup() {
            showToast('شروع فرآیند بکاپ‌گیری...', 'success');
        }

        function saveSettings() {
            showToast('تنظیمات با موفقیت ذخیره شد', 'success');
        }

        // ============= مدیریت فایل‌ها =============
        function showFileDetails(filename) {
            const detailsDiv = document.getElementById('file-details');
            document.getElementById('detail-filename').textContent = filename;
            document.getElementById('detail-path').textContent = '/backups/' + filename;
            document.getElementById('detail-date').textContent = '۱۴۰۴/۱۲/۰۸ - ۱۵:۳۰';
            detailsDiv.style.display = 'block';
        }

        function downloadFile(filename) {
            showToast('دانلود فایل: ' + filename, 'success');
        }

        function deleteFile(filename) {
            if(confirm('آیا از حذف این فایل اطمینان دارید؟')) {
                showToast('فایل با موفقیت حذف شد', 'success');
            }
        }

        // ============= تابع نمایش پیام =============
        function showToast(message, type = 'success') {
            // ایجاد تایست اگر وجود ندارد
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.className = 'toast';
                document.body.appendChild(toast);
            }
            
            toast.className = 'toast ' + type;
            toast.textContent = message;
            toast.style.display = 'block';
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 2000);
        }
    </script>
</body>
</html>