<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; }
        body { background: #f0f4f0; display: flex; min-height: 100vh; }
        
        .sidebar { width: 280px; background: linear-gradient(180deg, #0b3b2c, #1a6d4c); color: white; position: fixed; height: 100vh; }
        .sidebar-header { padding: 30px 24px; border-bottom: 1px solid rgba(255,215,0,0.2); }
.sidebar-header h2 { 
    font-size: 24px; 
    background: linear-gradient(135deg, #fff, #d4af37); 
    -webkit-background-clip: text; 
    background-clip: text; 
    -webkit-text-fill-color: transparent; 
    color: transparent; 
}        .nav-menu { padding: 20px 0; }
        .nav-item { padding: 12px 24px; margin: 4px 8px; border-radius: 12px; display: flex; align-items: center; gap: 12px; color: #e0f0e0; text-decoration: none; }
        .nav-item:hover, .nav-item.active { background: rgba(255,255,255,0.1); color: #d4af37; }
        
        .main-content { margin-right: 280px; flex: 1; padding: 30px; width: calc(100% - 280px); }
        .header { background: white; padding: 20px 30px; border-radius: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { color: #0b3b2c; }
        .add-btn { background: #1a6d4c; color: white; padding: 10px 20px; border-radius: 12px; text-decoration: none; }
        
        .brokers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .broker-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #eef2f0; }
        .broker-header { display: flex; align-items: center; gap: 15px; margin-bottom: 15px; }
        .broker-logo { width: 50px; height: 50px; background: #f0f4f0; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .broker-name { font-size: 18px; font-weight: 600; color: #0b3b2c; }
        .broker-desc { color: #4b5563; font-size: 14px; margin-bottom: 15px; }
        .broker-meta { display: flex; justify-content: space-between; color: #64748b; font-size: 13px; margin-bottom: 15px; }
        .broker-actions { display: flex; gap: 10px; }
        .broker-actions a { padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 13px; }
        .edit-btn { background: #f0f4f0; color: #0b3b2c; }
        .delete-btn { background: #fee2e2; color: #dc2626; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <h2>PhoenixTrade</h2>
        </div>
        <div class="nav-menu">
            <a href="/pprofessor/dashboard" class="nav-item">📊 داشبورد</a>
            <a href="/pprofessor/lessons" class="nav-item">📚 درس‌ها</a>
            <a href="/pprofessor/brokers" class="nav-item active">🏢 بروکرها</a>
            <a href="/pprofessor/events" class="nav-item">📅 رویدادها</a>
            <a href="/pprofessor/bot" class="nav-item">🤖 ربات</a>
            <a href="/pprofessor/webapp" class="nav-item">🌐 WebApp</a>
            <a href="/pprofessor/backup" class="nav-item">💾 بکاپ</a>
            <a href="/pprofessor/api" class="nav-item">🔧 API</a>
        </div>
    </div>
    
    <div class="main-content">
        <div class="header">
            <h1><%= title %></h1>
            <a href="/pprofessor/brokers/new" class="add-btn">+ بروکر جدید</a>
        </div>
        
        <div class="brokers-grid">
            <% brokers.forEach(broker => { %>
            <div class="broker-card">
                <div class="broker-header">
                    <div class="broker-logo">🏢</div>
                    <div class="broker-name"><%= broker.name %></div>
                </div>
                <div class="broker-desc"><%= broker.description %></div>
                <div class="broker-meta">
                    <span>💰 حداقل واریز: <%= broker.minDeposit || '-' %>$</span>
                    <span>📊 وضعیت: <%= broker.isActive ? 'فعال' : 'غیرفعال' %></span>
                </div>
                <div class="broker-actions">
                    <a href="/pprofessor/brokers/<%= broker.id %>/edit" class="edit-btn">ویرایش</a>
                    <a href="/pprofessor/brokers/<%= broker.id %>/delete" class="delete-btn" onclick="return confirm('حذف شود؟')">حذف</a>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</body>
</html>