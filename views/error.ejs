<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خطا - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- استایل سراسری پنل -->
    <link rel="stylesheet" href="/css/admin.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .error-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .error-box {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 3rem;
            max-width: 600px;
            width: 100%;
            text-align: center;
            border: 1px solid rgba(255, 215, 0, 0.3);
        }
        .error-icon {
            font-size: 5rem;
            color: #ffd700;
            margin-bottom: 1.5rem;
        }
        .error-title {
            color: #ffd700;
            font-size: 2rem;
            margin-bottom: 1rem;
        }
        .error-message {
            color: #fff;
            font-size: 1.1rem;
            margin-bottom: 2rem;
            line-height: 1.8;
        }
        .error-details {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            padding: 1rem;
            margin-bottom: 2rem;
            text-align: left;
            direction: ltr;
            font-family: monospace;
            color: #ffd700;
            font-size: 0.9rem;
            overflow-x: auto;
        }
        .btn {
            display: inline-block;
            background: linear-gradient(135deg, #ffd700, #b8860b);
            color: #0a2f1f;
            text-decoration: none;
            padding: 1rem 2.5rem;
            border-radius: 30px;
            font-weight: bold;
            transition: all 0.3s;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(255, 215, 0, 0.3);
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-box">
            <div class="error-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h1 class="error-title"><%= title || 'خطا' %></h1>
            <div class="error-message">
                <%= message || 'خطایی در اجرای درخواست رخ داده است.' %>
            </div>
            <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV === 'development') { %>
                <div class="error-details">
                    <strong><%= error.toString() %></strong>
                </div>
            <% } %>
            <a href="/pprofessor/dashboard" class="btn">
                <i class="fas fa-home"></i> بازگشت به داشبورد
            </a>
        </div>
    </div>
</body>
</html>