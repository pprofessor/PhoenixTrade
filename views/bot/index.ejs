<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Vazir', 'Tahoma', sans-serif; }
        body { background: linear-gradient(135deg, #0a2f1f 0%, #1a4a2c 100%); min-height: 100vh; display: flex; }
        
        /* سایدبار */
        .sidebar { width: 280px; background: rgba(0, 20, 10, 0.95); backdrop-filter: blur(10px); border-left: 1px solid #b8860b; padding: 2rem 1rem; color: #fff; }
        .logo { font-size: 1.8rem; font-weight: bold; color: #ffd700; text-shadow: 0 0 10px rgba(255,215,0,0.5); margin-bottom: 2rem; text-align: center; }
        .menu-item { display: flex; align-items: center; gap: 0.8rem; padding: 1rem; margin: 0.5rem 0; border-radius: 15px; color: #fff; text-decoration: none; transition: all 0.3s; }
        .menu-item:hover, .menu-item.active { background: linear-gradient(135deg, #2a5a3a, #1a3a2a); border-right: 3px solid #ffd700; }
        .menu-item i { width: 24px; color: #ffd700; }
        
        /* محتوای اصلی */
        .main-content { flex: 1; padding: 2rem; }
        .header { background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 20px; padding: 1.5rem; margin-bottom: 2rem; border: 1px solid rgba(255,215,0,0.3); }
        .header h1 { color: #ffd700; font-size: 2rem; }
        
        /* تب‌ها */
        .tabs { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
        .tab { padding: 0.8rem 2rem; background: rgba(255,255,255,0.1); backdrop-filter: blur(5px); border-radius: 30px; color: #fff; cursor: pointer; transition: all 0.3s; border: 1px solid transparent; }
        .tab:hover { background: rgba(255,215,0,0.2); border-color: #b8860b; }
        .tab.active { background: #ffd700; color: #0a2f1f; font-weight: bold; border-color: #b8860b; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        
        /* کارت‌ها */
        .card { background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 25px; padding: 2rem; margin-bottom: 2rem; border: 1px solid rgba(255,215,0,0.3); box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
        .card h3 { color: #ffd700; margin-bottom: 1.5rem; font-size: 1.5rem; }
        
        /* فرم‌ها */
        .form-group { margin-bottom: 1.5rem; }
        .form-group label { display: block; color: #ffd700; margin-bottom: 0.5rem; font-weight: bold; }
        .form-control { width: 100%; padding: 1rem; border-radius: 20px; border: 2px solid rgba(255,215,0,0.3); background: rgba(0,0,0,0.3); color: #fff; font-size: 1rem; transition: all 0.3s; }
        .form-control:focus { outline: none; border-color: #ffd700; box-shadow: 0 0 15px rgba(255,215,0,0.5); }
        select.form-control { appearance: none; background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23ffd700'%3e%3cpath d='M7 10l5 5 5-5z'/%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: left 1rem center; background-size: 1.5rem; }
        
        /* گرید منوها */
        .menus-container { display: flex; flex-direction: column; gap: 1rem; }
        .menu-card { background: linear-gradient(135deg, rgba(255,215,0,0.1), rgba(0,0,0,0.3)); border-radius: 20px; padding: 1.5rem; border: 1px solid #b8860b; }
        .menu-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
        .menu-title { color: #ffd700; font-weight: bold; font-size: 1.3rem; }
        .submenu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; margin-top: 1rem; }
        .submenu-card { background: rgba(0,0,0,0.3); border-radius: 15px; padding: 1rem; border-right: 3px solid #ffd700; }
        
        /* ایموجی پیکر */
        .emoji-picker { display: grid; grid-template-columns: repeat(8, 1fr); gap: 0.5rem; margin-top: 1rem; max-height: 200px; overflow-y: auto; padding: 1rem; background: rgba(0,0,0,0.3); border-radius: 20px; }
        .emoji-item { font-size: 2rem; padding: 0.5rem; text-align: center; cursor: pointer; border-radius: 15px; transition: all 0.3s; }
        .emoji-item:hover { background: #ffd700; transform: scale(1.2); }
        
        /* دکمه‌ها */
        .btn { background: linear-gradient(135deg, #ffd700, #b8860b); color: #0a2f1f; border: none; padding: 1rem 2rem; border-radius: 30px; font-weight: bold; cursor: pointer; transition: all 0.3s; font-size: 1rem; }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 5px 20px rgba(255,215,0,0.5); }
        .btn-sm { padding: 0.6rem 1.5rem; font-size: 0.9rem; }
        .btn-danger { background: linear-gradient(135deg, #dc3545, #a71d2a); color: #fff; }
        
        /* جدول */
        .table-container { overflow-x: auto; border-radius: 20px; background: rgba(0,0,0,0.2); padding: 1rem; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { background: rgba(255,215,0,0.2); color: #ffd700; padding: 1rem; text-align: right; font-weight: bold; }
        .data-table td { padding: 1rem; color: #fff; border-bottom: 1px solid rgba(255,215,0,0.1); }
        .data-table tr:hover { background: rgba(255,255,255,0.1); }
        
        /* وضعیت ربات */
        .bot-status { background: linear-gradient(135deg, rgba(0,0,0,0.3), rgba(255,215,0,0.1)); border-radius: 30px; padding: 1.5rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
        .status-indicator { display: flex; align-items: center; gap: 0.8rem; background: rgba(0,0,0,0.3); padding: 0.5rem 1.5rem; border-radius: 30px; }
        .status-dot { width: 12px; height: 12px; border-radius: 50%; background: #0f0; box-shadow: 0 0 10px #0f0; }
        
        /* تایست (پیام پاپ‌آپ) */
        .toast { 
            position: fixed; 
            top: 50%; 
            left: 50%; 
            transform: translate(-50%, -50%); 
            padding: 1rem 2rem; 
            border-radius: 30px; 
            color: #fff; 
            font-weight: bold; 
            z-index: 9999; 
            display: none; 
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
            text-align: center;
            min-width: 200px;
        }
        .toast.success { background: linear-gradient(135deg, #28a745, #1e7e34); }
        .toast.error { background: linear-gradient(135deg, #dc3545, #a71d2a); }
    </style>
</head>
<body>
    <!-- تایست (پیام پاپ‌آپ) وسط صفحه -->
    <div id="toast" class="toast"></div>

    <!-- سایدبار -->
    <div class="sidebar">
        <div class="logo">PhoenixTrade</div>
        <nav>
            <a href="/pprofessor/dashboard" class="menu-item"><i class="fas fa-home"></i>داشبورد</a>
            <a href="/pprofessor/backup" class="menu-item"><i class="fas fa-database"></i>مدیریت بکاپ</a>
            <a href="/pprofessor/database" class="menu-item"><i class="fas fa-server"></i>مدیریت دیتابیس</a>
            <a href="/pprofessor/bot" class="menu-item active"><i class="fas fa-robot"></i>مدیریت ربات</a>
            <a href="/pprofessor/webapp" class="menu-item"><i class="fas fa-globe"></i>مدیریت وب اپ</a>
            <a href="/pprofessor/api-settings" class="menu-item"><i class="fas fa-code"></i>تنظیمات API</a>
            <a href="/pprofessor/logout" class="menu-item" style="margin-top:2rem;"><i class="fas fa-sign-out-alt"></i>خروج</a>
        </nav>
    </div>

    <!-- محتوای اصلی -->
    <div class="main-content">
        <div class="header">
            <h1><i class="fas fa-robot"></i> مدیریت ربات</h1>
        </div>

        <!-- وضعیت ربات -->
        <div class="bot-status">
            <div class="status-indicator">
                <span class="status-dot"></span>
                <span style="color: #fff;" id="bot-status-text">بررسی وضعیت...</span>
            </div>
            <div class="bot-token" style="background:rgba(0,0,0,0.3); padding:0.5rem 1.5rem; border-radius:30px; direction:ltr;">8223148206:AAGI...FhonQ</div>
            <button class="btn btn-sm" onclick="testBot()"><i class="fas fa-sync"></i> تست اتصال</button>
        </div>

        <!-- تب‌ها -->
        <div class="tabs">
            <div class="tab active" onclick="showTab('messages')">پیام‌ها</div>
            <div class="tab" onclick="showTab('menus')">منوها</div>
            <div class="tab" onclick="showTab('users')">کاربران</div>
        </div>

        <!-- تب پیام‌ها -->
        <div id="tab-messages" class="tab-content active">
            <div class="card">
                <h3><i class="fas fa-comment"></i> پیام‌های ربات</h3>
                
                <div class="form-group">
                    <label>پیام خوش‌آمدگویی (کاربران جدید)</label>
                    <textarea id="welcome-new" class="form-control" rows="4"><% 
                        let welcomeNew = messages ? messages.find(m => m.key === 'welcome_new') : null;
                        %><%= welcomeNew ? welcomeNew.text : 'به ربات خوش آمدید' %></textarea>
                </div>

                <div class="form-group">
                    <label>پیام خوش‌آمدگویی (کاربران قبلی)</label>
                    <textarea id="welcome-return" class="form-control" rows="4"><% 
                        let welcomeReturn = messages ? messages.find(m => m.key === 'welcome_return') : null;
                        %><%= welcomeReturn ? welcomeReturn.text : 'خوش آمدید' %></textarea>
                </div>

                <button class="btn" onclick="saveMessages()"><i class="fas fa-save"></i> ذخیره پیام‌ها</button>
            </div>
        </div>

        <!-- تب منوها -->
        <div id="tab-menus" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-bars"></i> مدیریت منوها</h3>
                
                <button class="btn" onclick="showMenuForm()" style="margin-bottom:2rem;">
                    <i class="fas fa-plus"></i> منوی جدید
                </button>

<!-- نمایش منوها -->
<div class="menus-container">
    <% if (mainMenus && mainMenus.length > 0) { 
        for (let i=0; i<mainMenus.length; i++) { 
            let menu = mainMenus[i];
            // پیدا کردن زیرمنوهای این منو
            let submenus = menus.filter(m => m.parentId == menu.id);
    %>
    <div class="menu-card">
        <div class="menu-header">
            <span class="menu-title"><%= menu.emoji || '🔹' %> <%= menu.text %></span>
            <div>
                <button class="btn btn-sm" onclick="editMenu('<%= menu.id %>')"><i class="fas fa-edit"></i></button>
                <button class="btn btn-sm btn-danger" onclick="deleteMenu('<%= menu.id %>')"><i class="fas fa-trash"></i></button>
            </div>
        </div>
        
        <% if (submenus.length > 0) { %>
        <div class="submenu-grid">
            <% for (let j=0; j<submenus.length; j++) { 
                let sub = submenus[j];
            %>
            <div class="submenu-card">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <span><%= sub.emoji || '🔸' %> <%= sub.text %></span>
                    <div>
                        <button class="btn btn-sm" onclick="editMenu('<%= sub.id %>')"><i class="fas fa-edit"></i></button>
                        <button class="btn btn-sm btn-danger" onclick="deleteMenu('<%= sub.id %>')"><i class="fas fa-trash"></i></button>
                    </div>
                </div>
                <% if (sub.content) { %>
                <div style="margin-top:0.5rem; font-size:0.8rem; color:#aaa;"><%= sub.content.substring(0,50) %></div>
                <% } %>
            </div>
            <% } %>
        </div>
        <% } %>
    </div>
    <% } } else { %>
    <p style="color:#fff; text-align:center;">هیچ منویی تعریف نشده است</p>
    <% } %>
</div>

                <!-- فرم ایجاد/ویرایش منو -->
                <div id="menu-form" style="display:none; margin-top:2rem;">
                    <h4 id="menu-form-title" style="color:#ffd700; margin-bottom:1rem;">ایجاد منوی جدید</h4>
                    <input type="hidden" id="menu-id">
                    
                    <div class="form-group">
                        <label>متن نمایشی منو</label>
                        <input type="text" id="menu-text" class="form-control" placeholder="مثلاً دوره‌های آموزشی" required>
                    </div>

                    <div class="form-group">
                        <label>نوع منو</label>
                        <select id="menu-type" class="form-control" onchange="toggleParentSelect()">
                            <option value="main">منوی اصلی</option>
                            <option value="submenu">زیرمنو</option>
                        </select>
                    </div>

<div class="form-group" id="parent-select-group" style="display:none;">
    <label>منوی والد</label>
    <select id="menu-parent" class="form-control">
        <option value="">انتخاب کنید</option>
        <% if (menus && menus.length > 0) { 
            for (let i=0; i<menus.length; i++) { 
                // فقط منوهایی که میتونن والد باشن
        %>
        <option value="<%= menus[i].id %>"><%= menus[i].text %></option>
        <% } } %>
    </select>
</div>

                    <div class="form-group">
                        <label>متن نمایشی (وقتی کاربر کلیک میکنه)</label>
                        <textarea id="menu-content" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label>ایموجی</label>
                        <div class="emoji-picker">
                            <div class="emoji-item" onclick="selectEmoji('🔹')">🔹</div>
                            <div class="emoji-item" onclick="selectEmoji('📚')">📚</div>
                            <div class="emoji-item" onclick="selectEmoji('💹')">💹</div>
                            <div class="emoji-item" onclick="selectEmoji('📅')">📅</div>
                            <div class="emoji-item" onclick="selectEmoji('👤')">👤</div>
                            <div class="emoji-item" onclick="selectEmoji('📞')">📞</div>
                            <div class="emoji-item" onclick="selectEmoji('❓')">❓</div>
                            <div class="emoji-item" onclick="selectEmoji('⚡')">⚡</div>
                            <div class="emoji-item" onclick="selectEmoji('⭐')">⭐</div>
                            <div class="emoji-item" onclick="selectEmoji('🏠')">🏠</div>
                            <div class="emoji-item" onclick="selectEmoji('📊')">📊</div>
                            <div class="emoji-item" onclick="selectEmoji('📈')">📈</div>
                            <div class="emoji-item" onclick="selectEmoji('💰')">💰</div>
                            <div class="emoji-item" onclick="selectEmoji('🔔')">🔔</div>
                            <div class="emoji-item" onclick="selectEmoji('⚙️')">⚙️</div>
                            <div class="emoji-item" onclick="selectEmoji('🔗')">🔗</div>
                        </div>
                        <input type="text" id="menu-emoji" class="form-control" style="margin-top:1rem;" placeholder="ایموجی انتخاب شده">
                    </div>

                    <div class="form-group">
                        <label>اتصال به API</label>
                        <select id="menu-api" class="form-control">
                            <option value="">بدون API</option>
                            <% if (apis && apis.length > 0) { 
                                for (let i=0; i<apis.length; i++) { 
                                    let api = apis[i]; %>
                            <option value="/api/<%= api.slug %>"><%= api.title %> (/api/<%= api.slug %>)</option>
                            <% } } %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>ترتیب نمایش</label>
                        <input type="number" id="menu-order" class="form-control" value="0">
                    </div>

                    <div style="display:flex; gap:1rem;">
                        <button class="btn" onclick="saveMenu()"><i class="fas fa-save"></i> ذخیره</button>
                        <button class="btn btn-danger" onclick="cancelMenuForm()"><i class="fas fa-times"></i> انصراف</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- تب کاربران -->
        <div id="tab-users" class="tab-content">
            <div class="card">
                <h3><i class="fas fa-users"></i> کاربران ربات</h3>
                
                <div style="display:flex; gap:1rem; margin-bottom:2rem;">
                    <input type="text" id="user-search" class="form-control" placeholder="جستجو در نام، شماره، ایمیل...">
                    <button class="btn" onclick="searchUsers()"><i class="fas fa-search"></i> جستجو</button>
                </div>

                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>نام</th>
                                <th>نام خانوادگی</th>
                                <th>یوزرنیم</th>
                                <th>شماره تماس</th>
                                <th>کد ملی</th>
                                <th>تاریخ ثبت</th>
                                <th>عملیات</th>
                            </tr>
                        </thead>
                        <tbody id="users-container">
                            <tr><td colspan="7" style="text-align:center;">در حال بارگذاری...</td></tr>
                        </tbody>
                    </table>
                </div>

                <!-- فرم ارسال پیام به کاربر -->
                <div id="message-user-form" style="display:none; margin-top:2rem;">
                    <h4 style="color:#ffd700;">ارسال پیام به کاربر</h4>
                    <input type="hidden" id="message-user-id">
                    <div class="form-group">
                        <textarea id="message-user-text" class="form-control" rows="3" placeholder="متن پیام..."></textarea>
                    </div>
                    <button class="btn" onclick="sendMessageToUser()"><i class="fas fa-paper-plane"></i> ارسال</button>
                    <button class="btn btn-danger" onclick="cancelMessageUser()">انصراف</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let selectedApi = null;

        // تابع نمایش پیام پاپ‌آپ در وسط صفحه
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            toast.className = 'toast ' + type;
            toast.textContent = message;
            toast.style.display = 'block';
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 2000);
        }

        // نمایش تب
        function showTab(tabName) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('tab-' + tabName).classList.add('active');
            if (tabName === 'users') loadUsers();
        }

        // وضعیت ربات
        function testBot() {
            fetch('/pprofessor/api/bot/status')
                .then(res => res.json())
                .then(data => {
                    if (data.online) {
                        document.getElementById('bot-status-text').innerHTML = '✅ آنلاین - @' + data.username;
                        showToast('✅ ربات آنلاین است', 'success');
                    } else {
                        document.getElementById('bot-status-text').innerHTML = '❌ آفلاین';
                        showToast('❌ ربات آفلاین است', 'error');
                    }
                })
                .catch(() => {
                    document.getElementById('bot-status-text').innerHTML = '❌ خطا در اتصال';
                    showToast('❌ خطا در اتصال به ربات', 'error');
                });
        }

        // ذخیره پیام‌ها
        function saveMessages() {
            const messages = [
                { key: 'welcome_new', text: document.getElementById('welcome-new').value },
                { key: 'welcome_return', text: document.getElementById('welcome-return').value }
            ];
            
            Promise.all(messages.map(msg => 
                fetch('/pprofessor/api/bot/messages', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify(msg)
                })
            ))
            .then(() => {
                showToast('✅ پیام‌ها با موفقیت ذخیره شدند', 'success');
            })
            .catch(() => {
                showToast('❌ خطا در ذخیره پیام‌ها', 'error');
            });
        }

        // منوها
        function showMenuForm() {
            document.getElementById('menu-form').style.display = 'block';
            document.getElementById('menu-form-title').innerText = 'ایجاد منوی جدید';
            document.getElementById('menu-id').value = '';
            document.getElementById('menu-text').value = '';
            document.getElementById('menu-type').value = 'main';
            document.getElementById('menu-emoji').value = '🔹';
            document.getElementById('menu-content').value = '';
            document.getElementById('menu-api').value = '';
            document.getElementById('menu-order').value = '0';
            toggleParentSelect();
        }

        function toggleParentSelect() {
            const type = document.getElementById('menu-type').value;
            const parentGroup = document.getElementById('parent-select-group');
            if (type === 'submenu') {
                parentGroup.style.display = 'block';
            } else {
                parentGroup.style.display = 'none';
            }
        }

        function selectEmoji(emoji) {
            document.getElementById('menu-emoji').value = emoji;
        }

        function editMenu(id) {
            fetch('/pprofessor/api/bot/menus')
                .then(res => res.json())
                .then(menus => {
                    let menu = menus.find(m => m.id == id);
                    if (menu) {
                        document.getElementById('menu-form').style.display = 'block';
                        document.getElementById('menu-form-title').innerText = 'ویرایش منو';
                        document.getElementById('menu-id').value = menu.id;
                        document.getElementById('menu-text').value = menu.text || '';
                        document.getElementById('menu-type').value = menu.type || 'main';
                        document.getElementById('menu-emoji').value = menu.emoji || '🔹';
                        document.getElementById('menu-content').value = menu.content || '';
                        document.getElementById('menu-api').value = menu.apiEndpoint || '';
                        document.getElementById('menu-order').value = menu.order || 0;
                        document.getElementById('menu-parent').value = menu.parentId || '';
                        toggleParentSelect();
                    }
                });
        }

        function saveMenu() {
            let id = document.getElementById('menu-id').value;
            
            let parentId = null;
            if (document.getElementById('menu-type').value === 'submenu') {
                parentId = document.getElementById('menu-parent').value;
                if (!parentId) {
                    showToast('❌ لطفاً منوی والد را انتخاب کنید', 'error');
                    return;
                }
            }
            
            let data = {
                text: document.getElementById('menu-text').value,
                type: document.getElementById('menu-type').value,
                emoji: document.getElementById('menu-emoji').value,
                content: document.getElementById('menu-content').value,
                apiEndpoint: document.getElementById('menu-api').value || null,
                order: parseInt(document.getElementById('menu-order').value) || 0,
                parentId: parentId
            };
            
            let url = id ? '/pprofessor/api/bot/menus/' + id : '/pprofessor/api/bot/menus';
            let method = id ? 'PUT' : 'POST';
            
            fetch(url, {
                method: method,
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(result => {
                if (result.error) {
                    showToast('❌ ' + result.error, 'error');
                } else {
                    showToast(id ? '✅ منو ویرایش شد' : '✅ منو ایجاد شد', 'success');
                    setTimeout(() => location.reload(), 1000);
                }
            })
            .catch(err => {
                showToast('❌ خطا در ذخیره منو', 'error');
            });
        }

        function deleteMenu(id) {
            if (confirm('آیا از حذف این منو اطمینان دارید؟')) {
                fetch('/pprofessor/api/bot/menus/' + id, {method:'DELETE'})
                .then(res => res.json())
                .then(result => {
                    if (result.error) {
                        showToast('❌ ' + result.error, 'error');
                    } else {
                        showToast('✅ منو حذف شد', 'success');
                        setTimeout(() => location.reload(), 1000);
                    }
                })
                .catch(() => {
                    showToast('❌ خطا در حذف منو', 'error');
                });
            }
        }

        function cancelMenuForm() {
            document.getElementById('menu-form').style.display = 'none';
        }

        // کاربران
        function loadUsers() {
            fetch('/pprofessor/api/bot/users')
                .then(res => res.json())
                .then(users => {
                    let html = '';
                    if (users.length === 0) {
                        html = '<tr><td colspan="7" style="text-align:center;">کاربری یافت نشد</td></tr>';
                    } else {
                        for (let u of users) {
                            let date = new Date(u.createdAt).toLocaleDateString('fa-IR');
                            html += '<tr>' +
                                '<td>' + (u.firstName || '-') + '</td>' +
                                '<td>' + (u.lastName || '-') + '</td>' +
                                '<td>' + (u.username || '-') + '</td>' +
                                '<td>' + (u.phone || '-') + '</td>' +
                                '<td>' + (u.nationalCode || '-') + '</td>' +
                                '<td>' + date + '</td>' +
                                '<td><button class="btn btn-sm" onclick="showMessageForm(' + u.id + ')"><i class="fas fa-envelope"></i> پیام</button></td>' +
                                '</tr>';
                        }
                    }
                    document.getElementById('users-container').innerHTML = html;
                });
        }

        function searchUsers() {
            loadUsers();
        }

        function showMessageForm(userId) {
            document.getElementById('message-user-id').value = userId;
            document.getElementById('message-user-form').style.display = 'block';
        }

        function sendMessageToUser() {
            showToast('📝 ارسال پیام - در حال توسعه', 'success');
        }

        function cancelMessageUser() {
            document.getElementById('message-user-form').style.display = 'none';
        }

        // تست وضعیت اولیه
        testBot();
    </script>
</body>
</html>