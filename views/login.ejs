<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - PhoenixTrade</title>
    <!-- فونت سمیم -->
    <link rel="stylesheet" href="/css/fonts.css">
    <!-- Font Awesome (برای آیکون‌های احتمالی) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'Samim', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; 
        }
        
        body { 
            background: linear-gradient(135deg, #0b3b2c, #1a6d4c); 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            padding: 20px; 
            position: relative;
            overflow: hidden;
        }
        
        /* افکت درخشش زمردی (مشابه پنل) */
        body::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 30%, rgba(255, 215, 0, 0.1) 0%, rgba(26, 109, 76, 0.4) 50%, transparent 70%);
            animation: emeraldGlow 15s ease infinite;
            pointer-events: none;
            z-index: 0;
        }
        
        @keyframes emeraldGlow {
            0% { transform: rotate(0deg) scale(1); opacity: 0.5; }
            50% { transform: rotate(5deg) scale(1.05); opacity: 0.8; }
            100% { transform: rotate(0deg) scale(1); opacity: 0.5; }
        }
        
        .login-container { 
            background: rgba(255, 255, 255, 0.95); 
            border-radius: 32px; 
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); 
            width: 100%; 
            max-width: 440px; 
            padding: 40px; 
            backdrop-filter: blur(10px); 
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 215, 0, 0.3); 
            position: relative;
            z-index: 10;
        }
        
        .logo { 
            text-align: center; 
            margin-bottom: 32px; 
        }
        
        .logo h1 { 
            font-size: 32px; 
            font-weight: 700; 
            background: linear-gradient(135deg, #0b3b2c, #1a6d4c, #d4af37); 
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent; 
            background-clip: text; 
            margin-bottom: 8px;
        }
        
        .logo span { 
            color: #d4af37; 
            font-size: 14px; 
            letter-spacing: 1px; 
            display: block;
        }
        
        .form-group { 
            margin-bottom: 24px; 
        }
        
        label { 
            display: block; 
            margin-bottom: 8px; 
            color: #0b3b2c; 
            font-weight: 500; 
            font-size: 14px; 
        }
        
        input { 
            width: 100%; 
            padding: 14px 16px; 
            border: 2px solid #e0e7e0; 
            border-radius: 16px; 
            font-size: 15px; 
            transition: all 0.3s; 
            background: white; 
            font-family: 'Samim', sans-serif;
        }
        
        input:focus { 
            outline: none; 
            border-color: #1a6d4c; 
            box-shadow: 0 0 0 4px rgba(26, 109, 76, 0.1); 
        }
        
        .error { 
            background: rgba(254, 226, 226, 0.9); 
            backdrop-filter: blur(5px);
            color: #b91c1c; 
            padding: 12px 16px; 
            border-radius: 12px; 
            margin-bottom: 24px; 
            font-size: 14px; 
            text-align: center; 
            border: 1px solid #fecaca; 
        }
        
        button { 
            width: 100%; 
            padding: 14px; 
            background: linear-gradient(135deg, #0b3b2c, #1a6d4c); 
            color: white; 
            border: none; 
            border-radius: 16px; 
            font-size: 16px; 
            font-weight: 600; 
            cursor: pointer; 
            transition: all 0.3s; 
            box-shadow: 0 4px 6px -1px rgba(11, 59, 44, 0.2); 
            font-family: 'Samim', sans-serif;
        }
        
        button:hover { 
            transform: translateY(-2px); 
            box-shadow: 0 10px 15px -3px rgba(11, 59, 44, 0.3); 
            background: linear-gradient(135deg, #0f4c3a, #1f8b60); 
        }
        
        .gold-text { 
            color: #d4af37; 
            font-weight: 600; 
        }
        
        .footer { 
            text-align: center; 
            margin-top: 24px; 
            color: #4b5563; 
            font-size: 13px; 
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="logo">
            <h1>🦅 PhoenixTrade</h1>
            <span>پنل مدیریت</span>
        </div>
        
        <% if (locals.error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <form action="/pprofessor/login" method="POST">
            <div class="form-group">
                <label>نام کاربری</label>
                <input type="text" name="username" placeholder="pprofessor" required autofocus>
            </div>
            
            <div class="form-group">
                <label>رمز عبور</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>
            
            <button type="submit">
                <i class="fas fa-sign-in-alt" style="margin-left: 8px;"></i>
                ورود به پنل
            </button>
        </form>
        
        <div class="footer">
            <span class="gold-text">⚡ نسخه 1.0</span>
        </div>
    </div>
</body>
</html>